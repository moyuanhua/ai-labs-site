---
import { ClientRouter } from 'astro:transitions';
import ChatLayer from '../components/ChatLayer.astro';

interface Props {
  title: string;
  description?: string;
  chatVariant?: 'hero' | 'dock' | 'fullscreen';
}
const { title, description = 'HTML-first content publishing', chatVariant = 'dock' } = Astro.props;
import '../styles/global.css';
const BASE = import.meta.env.BASE_URL;
const navLinks = [
  { href: `${BASE}posts`,   label: 'Posts' },
  { href: `${BASE}roadmap`, label: 'Roadmap' },
  { href: `${BASE}about`,   label: 'About' },
  { href: `${BASE}chat`,    label: 'Chat', soon: true },
];
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" sizes="any" />
  <ClientRouter />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-bg text-text min-h-screen flex flex-col antialiased font-body overflow-x-hidden">
  <header class="sticky top-0 bg-bg/90 backdrop-blur-sm border-b border-border z-50">
    <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between gap-4 flex-wrap">
      <a
        href={BASE}
        class="font-heading text-2xl font-bold text-text hover:text-accent transition-colors duration-200 cursor-pointer"
      >
        ai-labs
      </a>
      <ul class="flex items-center gap-1 sm:gap-2 flex-wrap">
        {navLinks.map(link => {
          const isActive = currentPath === link.href || (link.href !== BASE && currentPath.startsWith(link.href));
          return (
            <li class="flex items-center">
              <a
                href={link.href}
                class={`px-2.5 py-1 text-sm font-medium font-body transition-colors duration-200 cursor-pointer ${
                  isActive
                    ? 'text-text font-semibold border-b-2 border-accent'
                    : 'text-text-muted hover:text-accent'
                }`}
              >
                {link.label}
                {link.soon && (
                  <span class="ml-1.5 text-[0.65rem] uppercase tracking-wider text-accent">soon</span>
                )}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </header>

  <main class="flex-1 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <slot />
  </main>

  <footer class="bg-dark text-white/70 py-12 mt-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col items-center gap-4">
      <p class="text-white text-sm sm:text-base font-body">Built with Astro · HTML-first · AI-ready</p>
      <ul class="flex items-center gap-3 text-xs uppercase tracking-widest text-white/60 font-body">
        <li><a href={`${BASE}posts`}   class="hover:text-white transition-colors duration-200 cursor-pointer">Posts</a></li>
        <li aria-hidden="true">·</li>
        <li><a href={`${BASE}roadmap`} class="hover:text-white transition-colors duration-200 cursor-pointer">Roadmap</a></li>
        <li aria-hidden="true">·</li>
        <li><a href={`${BASE}about`}   class="hover:text-white transition-colors duration-200 cursor-pointer">About</a></li>
      </ul>
      <p class="text-white/50 text-xs font-body">&copy; 2024 moyuanhua</p>
    </div>
  </footer>

  {chatVariant === 'dock' && <ChatLayer variant="dock" />}
</body>
</html>
