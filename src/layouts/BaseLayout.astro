---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'HTML-first content publishing' } = Astro.props;
import '../styles/global.css';
const BASE = import.meta.env.BASE_URL;
const navLinks = [
  { href: `${BASE}blog`, label: 'Blog' },
  { href: `${BASE}demos`, label: 'Demos' },
  { href: `${BASE}products`, label: 'Products' },
  { href: `${BASE}roadmap`, label: 'Roadmap' },
];
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,400..800,50&family=IBM+Plex+Mono:wght@300;400;500&display=swap" rel="stylesheet">
</head>
<body class="bg-bg text-ink min-h-screen flex flex-col antialiased font-mono">
  <header class="border-b border-rule sticky top-0 bg-bg/85 backdrop-blur-md z-50">
    <nav class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between gap-4 flex-wrap">
      <a href={BASE} class="font-serif text-xl font-semibold text-ink hover:text-accent transition-colors">
        ai-labs
      </a>
      <ul class="flex items-center gap-1 flex-wrap">
        {navLinks.map(link => {
          const isActive = currentPath === link.href || (link.href !== BASE && currentPath.startsWith(link.href));
          return (
            <li class="flex items-center">
              <a
                href={link.href}
                class={`px-2.5 py-1 rounded text-sm font-mono transition-colors ${
                  isActive
                    ? 'text-ink'
                    : 'text-ink-mute hover:text-ink'
                }`}
              >
                {isActive && <span class="text-accent mr-1" aria-hidden="true">·</span>}
                {link.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </header>

  <main class="flex-1 max-w-5xl mx-auto px-4 py-10 w-full">
    <slot />
  </main>

  <footer class="border-t border-rule py-8 mt-20 font-mono text-xs text-ink-faint">
    <p class="text-center">Built with Astro · HTML-first · AI-ready</p>
    <p class="text-center mt-1"><span class="opacity-50">—signals live—</span></p>
  </footer>
</body>
</html>
