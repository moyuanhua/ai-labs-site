---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'AI Labs — building the next generation of AI tools' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | AI Labs</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="logo">🤖 AI Labs</a>
        <nav>
          <a href="/blog">博客</a>
          <a href="/products">产品</a>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>&copy; {new Date().getFullYear()} AI Labs. Built with <a href="https://astro.build">Astro</a>.</p>
      </div>
    </footer>
  </body>
</html>

<style>
  .container {
    max-width: var(--max-width, 800px);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .site-header {
    border-bottom: 1px solid var(--color-border, #e5e7eb);
    padding: 1rem 0;
    margin-bottom: 2.5rem;
  }

  .site-header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text, #1a1a1a);
    text-decoration: none;
  }

  nav {
    display: flex;
    gap: 1.5rem;
  }

  nav a {
    font-weight: 500;
    color: var(--color-text, #1a1a1a);
  }

  nav a:hover {
    color: var(--color-accent, #4f46e5);
    text-decoration: none;
  }

  .site-footer {
    border-top: 1px solid var(--color-border, #e5e7eb);
    padding: 2rem 0;
    margin-top: 4rem;
    color: var(--color-text-muted, #555);
    font-size: 0.9rem;
    text-align: center;
  }
</style>
