---
import BaseLayout from './BaseLayout.astro';
import Giscus from '../components/Giscus.astro';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  heroImage?: string;
  category?: string;
  status?: 'active' | 'beta' | 'deprecated';
}

const { title, description, pubDate, heroImage, category, status = 'active' } = Astro.props;

const statusLabel: Record<string, string> = {
  active: '正式发布',
  beta: '公测中',
  deprecated: '已停用',
};

const statusClass: Record<string, string> = {
  active: 'status-active',
  beta: 'status-beta',
  deprecated: 'status-deprecated',
};
---

<BaseLayout title={title} description={description}>
  <article class="product-page">
    {heroImage && <img class="hero-image" src={heroImage} alt={title} />}

    <header class="product-header">
      <div class="product-meta">
        {category && <span class="category">{category}</span>}
        <span class={`status ${statusClass[status]}`}>{statusLabel[status]}</span>
      </div>
      <h1>{title}</h1>
      {description && <p class="description">{description}</p>}
    </header>

    <div class="product-content">
      <slot />
    </div>

    <!-- Giscus 评论区 -->
    <Giscus />
  </article>
</BaseLayout>

<style>
  .product-page {
    padding-bottom: 3rem;
  }

  .hero-image {
    width: 100%;
    max-height: 360px;
    object-fit: cover;
    margin-bottom: 2rem;
    border-radius: 0.75rem;
  }

  .product-header {
    margin-bottom: 2.5rem;
  }

  .product-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .category {
    background: var(--color-surface, #f9fafb);
    border: 1px solid var(--color-border, #e5e7eb);
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
    font-size: 0.8rem;
    color: var(--color-text-muted, #555);
  }

  .status {
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .status-active {
    background: #dcfce7;
    color: #166534;
  }

  .status-beta {
    background: #fef3c7;
    color: #92400e;
  }

  .status-deprecated {
    background: #fee2e2;
    color: #991b1b;
  }

  .product-header h1 {
    font-size: 2.25rem;
    margin-bottom: 0.75rem;
    color: var(--color-text, #1a1a1a);
  }

  .description {
    font-size: 1.1rem;
    color: var(--color-text-muted, #555);
  }

  .product-content {
    line-height: 1.8;
  }

  .product-content h2 {
    font-size: 1.6rem;
    margin: 2rem 0 1rem;
  }

  .product-content h3 {
    font-size: 1.25rem;
    margin: 1.5rem 0 0.75rem;
  }
</style>
