---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'AI Labs – Blog, Products & Roadmap' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | AI Labs</title>
  </head>
  <body>
    <nav class="nav">
      <a href="/" class="logo">🧪 AI Labs</a>
      <div class="links">
        <a href="/blog">Blog</a>
        <a href="/products">Products</a>
        <a href="/roadmap">Roadmap</a>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; {new Date().getFullYear()} AI Labs. All rights reserved.</p>
    </footer>
    <style is:global>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        font-family: system-ui, -apple-system, sans-serif;
        line-height: 1.6;
        color: #1a1a2e;
        background: #fafafa;
      }
      a {
        color: #4361ee;
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      main {
        max-width: 960px;
        margin: 2rem auto;
        padding: 0 1rem;
      }
      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 960px;
        margin: 0 auto;
        padding: 1rem;
      }
      .nav .logo {
        font-size: 1.25rem;
        font-weight: 700;
        color: inherit;
      }
      .nav .links {
        display: flex;
        gap: 1.5rem;
      }
      footer {
        text-align: center;
        padding: 2rem 1rem;
        color: #888;
        font-size: 0.85rem;
      }
    </style>
  </body>
</html>
