---
import BaseLayout from '../layouts/BaseLayout.astro';
import about from '../data/about.json';

type AboutItem = string | { label: string; url: string };
type AboutSection = { eyebrow: string; title: string; items: AboutItem[]; isContact?: boolean };

const sections: AboutSection[] = [
  { eyebrow: 'now · 现在',      title: '现在在做什么', items: about.now },
  { eyebrow: 'projects · 项目', title: '最近的项目',   items: about.projects },
  { eyebrow: 'skills · 工具',   title: '技能与工具',   items: about.skills },
  { eyebrow: 'contact · 联系',  title: '联系方式',     items: about.contact, isContact: true },
];

const isEmpty = (s: AboutSection) => s.items.length === 0;
const isContactItem = (item: AboutItem): item is { label: string; url: string } =>
  typeof item === 'object' && item !== null && 'label' in item && 'url' in item;
const allEmpty = sections.every(isEmpty);
---

<BaseLayout title="About — ai-labs" description="关于我">
  <article class="max-w-3xl mx-auto py-12">
    <p class="font-sans text-xs text-text-faint text-center mb-12">
      This page is empty until you fill in <code class="bg-surface-2 px-1.5 py-0.5 rounded border border-border font-mono text-text">src/data/about.json</code>.
    </p>

    <header class="mb-16 text-center" data-reveal>
      <p class="text-xs uppercase tracking-widest font-sans font-medium text-text-muted mb-4">
        about
      </p>
      <h1 class="font-script text-5xl sm:text-6xl font-bold text-text mb-4 tracking-tight">
        About
      </h1>
      <p class="font-sans text-base sm:text-lg text-text-muted max-w-xl mx-auto leading-relaxed">
        我是谁，我在做什么，我在用什么工具。
      </p>
    </header>

    {allEmpty && (
      <p class="font-sans text-text-faint text-center py-12 italic">— 整页待补充 —</p>
    )}

    <div class="space-y-16">
      {sections.map(section => (
        <section data-reveal>
          <p class="text-xs uppercase tracking-widest font-sans font-medium text-text-muted mb-3">
            {section.eyebrow}
          </p>
          <h2 class="font-script text-3xl sm:text-4xl font-bold text-text mb-4">
            {section.title}
          </h2>
          {isEmpty(section) ? (
            <p class="font-sans text-text-faint italic">— 待补充 —</p>
          ) : section.isContact ? (
            <ul class="space-y-2 font-sans text-sm">
              {section.items.map(item => {
                if (!isContactItem(item)) return null;
                return (
                  <li>
                    <span class="text-text-muted">{item.label}: </span>
                    <a
                      href={item.url}
                      class="text-accent hover:text-accent-2 underline underline-offset-2 transition-colors duration-200 cursor-pointer"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {item.url}
                    </a>
                  </li>
                );
              })}
            </ul>
          ) : (
            <ul class="font-sans text-sm text-text-muted space-y-2 list-none">
              {section.items.map(item => (
                <li class="flex gap-2">
                  <span class="text-accent shrink-0" aria-hidden="true">·</span>
                  <span class="text-text-muted">{String(item)}</span>
                </li>
              ))}
            </ul>
          )}
        </section>
      ))}
    </div>
  </article>
</BaseLayout>
