---
import BaseLayout from '../layouts/BaseLayout.astro';
import AmbientCanvas from '../components/AmbientCanvas.astro';
import about from '../data/about.json';

type AboutItem = string | { label: string; url: string };
type AboutSection = { eyebrow: string; title: string; items: AboutItem[]; isContact?: boolean };

const sections: AboutSection[] = [
  { eyebrow: 'now · 现在',         title: '现在在做什么',  items: about.now },
  { eyebrow: 'projects · 项目',    title: '最近的项目',    items: about.projects },
  { eyebrow: 'skills · 工具',      title: '技能与工具',    items: about.skills },
  { eyebrow: 'contact · 联系',     title: '联系方式',      items: about.contact, isContact: true },
];

const isEmpty = (s: AboutSection) => s.items.length === 0;
const isContactItem = (item: AboutItem): item is { label: string; url: string } =>
  typeof item === 'object' && item !== null && 'label' in item && 'url' in item;
const allEmpty = sections.every(isEmpty);
---

<BaseLayout title="About — ai-labs" description="关于我">
  <AmbientCanvas />

  <article class="max-w-3xl mx-auto">
    <p class="text-xs text-ink-faint text-center mb-12 font-mono">
      This page is empty until you fill in <code class="bg-surface px-1.5 py-0.5 rounded border border-rule">src/data/about.json</code>.
    </p>

    <header class="mb-16">
      <p class="text-xs uppercase tracking-wider font-mono text-ink-mute mb-3">about</p>
      <h1 class="font-serif text-4xl sm:text-5xl text-ink mb-3 tracking-tight">About</h1>
      <p class="font-mono text-ink-mute leading-relaxed">我是谁，我在做什么，我在用什么工具。</p>
    </header>

    {allEmpty && (
      <p class="font-mono text-ink-faint text-center py-12 italic">— 整页待补充 —</p>
    )}

    <div class="space-y-16">
      {sections.map(section => (
        <section>
          <p class="text-xs uppercase tracking-wider font-mono text-ink-mute mb-3">{section.eyebrow}</p>
          <h2 class="font-serif text-2xl text-ink mb-4">{section.title}</h2>
          {isEmpty(section) ? (
            <p class="font-mono text-ink-faint italic">— 待补充 —</p>
          ) : section.isContact ? (
            <ul class="space-y-1.5 font-mono text-sm">
              {section.items.map(item => {
                if (!isContactItem(item)) return null;
                return (
                  <li>
                    <span class="text-ink-mute">{item.label}: </span>
                    <a href={item.url} class="text-accent hover:text-accent-2 underline underline-offset-2" target="_blank" rel="noopener noreferrer">{item.url}</a>
                  </li>
                );
              })}
            </ul>
          ) : (
            <ul class="font-mono text-sm text-ink-mute space-y-1.5 list-none">
              {section.items.map(item => (
                <li class="flex gap-2">
                  <span class="text-accent shrink-0">·</span>
                  <span class="text-ink-mute">{String(item)}</span>
                </li>
              ))}
            </ul>
          )}
        </section>
      ))}
    </div>
  </article>
</BaseLayout>
