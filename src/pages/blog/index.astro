---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import AmbientCanvas from '../../components/AmbientCanvas.astro';
import { getCollection } from 'astro:content';

const BASE = import.meta.env.BASE_URL;
const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog — ai-labs" description="技术文章、思考与分享">
  <AmbientCanvas />

  <header class="mb-12">
    <p class="text-xs uppercase tracking-wider font-mono text-ink-mute mb-3">blog · index</p>
    <h1 class="font-serif text-4xl sm:text-5xl text-ink mb-3 tracking-tight">Blog</h1>
    <p class="font-mono text-ink-mute leading-relaxed">技术文章、思考与分享。每篇都是完整的 HTML 页面。</p>
  </header>

  {posts.length === 0 ? (
    <p class="font-mono text-ink-faint text-center py-20">— 暂无文章，敬请期待 —</p>
  ) : (
    <div class="grid gap-4 sm:grid-cols-2">
      {posts.map(post => (
        <ContentCard
          href={`${BASE}blog/${post.id}`}
          title={post.data.title}
          date={post.data.date}
          description={post.data.description}
          tags={post.data.tags}
        />
      ))}
    </div>
  )}
</BaseLayout>
