---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import { getCollection } from 'astro:content';

const BASE = import.meta.env.BASE_URL;
const posts = (await getCollection('posts'))
  .filter(p => !p.data.draft && p.data.type === 'blog')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog — ai-labs" description="技术文章、思考与分享">

  <header class="pt-16 pb-12 text-center">
    <p class="text-xs uppercase tracking-widest font-body font-medium text-text-muted mb-4">
      blog · index
    </p>
    <h1 class="font-heading text-4xl font-semibold text-text mb-4 tracking-tight">
      Blog
    </h1>
    <p class="font-body text-base sm:text-lg text-text-muted max-w-xl mx-auto leading-relaxed">
      技术文章、思考与分享。每篇都是完整的 HTML 页面。
    </p>
  </header>

  <section>
    {posts.length === 0 ? (
      <p class="font-body text-text-muted text-center py-20">— 暂无文章，敬请期待 —</p>
    ) : (
      <div class="grid gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map(post => (
          <ContentCard
            href={`${BASE}blog/${post.id}`}
            title={post.data.title}
            date={post.data.date}
            description={post.data.description}
            tags={post.data.tags}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>
