---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import { getCollection } from 'astro:content';

const BASE = import.meta.env.BASE_URL;
const demos = (await getCollection('posts'))
  .filter(p => !p.data.draft && p.data.type === 'demo')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Demos — ai-labs" description="交互式 Demo 展示">

  <header class="pt-16 pb-12 text-center">
    <p class="text-xs uppercase tracking-widest font-body font-medium text-text-muted mb-4">
      demos · index
    </p>
    <h1 class="font-heading text-4xl font-semibold text-text mb-4 tracking-tight">
      Demos
    </h1>
    <p class="font-body text-base sm:text-lg text-text-muted max-w-xl mx-auto leading-relaxed">
      交互式 Demo——HTML + JS Islands，按需激活。
    </p>
  </header>

  <section>
    {demos.length === 0 ? (
      <p class="font-body text-text-muted text-center py-20">— 暂无 Demo，敬请期待 —</p>
    ) : (
      <div class="grid gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
        {demos.map(demo => (
          <ContentCard
            href={`${BASE}demos/${demo.id}`}
            title={demo.data.title}
            date={demo.data.date}
            description={demo.data.description}
            tags={demo.data.tags}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>
