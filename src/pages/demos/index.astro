---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import AmbientCanvas from '../../components/AmbientCanvas.astro';
import { getCollection } from 'astro:content';

const BASE = import.meta.env.BASE_URL;
const demos = (await getCollection('demos'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Demos — ai-labs" description="交互式 Demo 展示">
  <AmbientCanvas />

  <header class="mb-12">
    <p class="text-xs uppercase tracking-wider font-mono text-ink-mute mb-3">demos · index</p>
    <h1 class="font-serif text-4xl sm:text-5xl text-ink mb-3 tracking-tight">Demos</h1>
    <p class="font-mono text-ink-mute leading-relaxed">交互式 Demo——HTML + JS Islands，按需激活。</p>
  </header>

  {demos.length === 0 ? (
    <p class="font-mono text-ink-faint text-center py-20">— 暂无 Demo，敬请期待 —</p>
  ) : (
    <div class="grid gap-4 sm:grid-cols-2">
      {demos.map(demo => (
        <ContentCard
          href={`${BASE}demos/${demo.id}`}
          title={demo.data.title}
          date={demo.data.date}
          description={demo.data.description}
          tags={demo.data.tags}
        />
      ))}
    </div>
  )}
</BaseLayout>
