---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AmbientCanvas from '../../components/AmbientCanvas.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const demos = await getCollection('demos');
  return demos
    .filter(p => !p.data.draft)
    .map(demo => ({ params: { slug: demo.id }, props: { demo } }));
}

const { demo } = Astro.props;
const { Content } = await render(demo);
const BASE = import.meta.env.BASE_URL;
---

<BaseLayout title={`${demo.data.title} — ai-labs`} description={demo.data.description}>
  <AmbientCanvas />

  <article class="max-w-2xl mx-auto">
    <a href={`${BASE}demos`} class="font-mono text-sm text-ink-mute hover:text-accent transition-colors">← Demos</a>

    <header class="mt-8 mb-10">
      <h1 class="font-serif text-3xl sm:text-4xl text-ink mb-4 leading-tight tracking-tight">{demo.data.title}</h1>
      <time datetime={demo.data.date.toISOString()} class="font-mono text-xs text-ink-mute">
        {demo.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      {demo.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-4">
          {demo.data.tags.map(tag => (
            <span class="text-xs font-mono text-ink-faint bg-surface px-2 py-0.5 rounded">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="prose-content">
      <Content />
    </div>
  </article>
</BaseLayout>
