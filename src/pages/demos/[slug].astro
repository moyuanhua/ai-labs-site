---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const demos = await getCollection('demos');
  return demos
    .filter(p => !p.data.draft)
    .map(demo => ({ params: { slug: demo.id }, props: { demo } }));
}

const { demo } = Astro.props;
const { Content } = await render(demo);
const BASE = import.meta.env.BASE_URL;
---

<BaseLayout title={`${demo.data.title} — ai-labs`} description={demo.data.description}>
  <article>
    <header class="mb-10">
      <div class="mb-4">
        <a href={`${BASE}demos`} class="text-sm text-slate-500 hover:text-indigo-400 transition-colors">← Demos</a>
      </div>
      <h1 class="text-3xl font-bold text-white mb-3 leading-tight">{demo.data.title}</h1>
      <div class="flex items-center gap-4 text-sm text-slate-500">
        <time datetime={demo.data.date.toISOString()}>
          {demo.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </div>
      {demo.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {demo.data.tags.map(tag => (
            <span class="text-xs px-2.5 py-1 rounded-md bg-slate-800 text-slate-400">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="prose-content">
      <Content />
    </div>
  </article>
</BaseLayout>
