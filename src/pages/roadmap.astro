---
import BaseLayout from '../layouts/BaseLayout.astro';
import AmbientCanvas from '../components/AmbientCanvas.astro';
import roadmap from '../data/roadmap.json';

const typeColors: Record<string, string> = {
  feature: 'text-accent   border-accent/50  bg-accent/10',
  content: 'text-accent-2 border-accent-2/50 bg-accent-2/10',
  infra:   'text-ink-faint border-rule     bg-surface',
};

const colStyles: Record<string, { header: string; dot: string }> = {
  planned:      { header: 'text-ink-faint', dot: 'bg-ink-faint' },
  'in-progress':{ header: 'text-accent',    dot: 'bg-accent' },
  done:         { header: 'text-accent-2',  dot: 'bg-accent-2' },
};
---

<BaseLayout title="Roadmap — ai-sites" description="我们正在做什么，打算做什么">
  <AmbientCanvas />

  <header class="mb-12">
    <p class="text-xs uppercase tracking-wider font-mono text-ink-mute mb-3">roadmap · live</p>
    <h1 class="font-serif text-4xl sm:text-5xl text-ink mb-3 tracking-tight">Roadmap</h1>
    <p class="font-mono text-ink-mute leading-relaxed">正在做什么，计划做什么，已经完成了什么。</p>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    {roadmap.columns.map(col => {
      const style = colStyles[col.id] ?? colStyles['planned'];
      return (
        <div>
          <div class="flex items-center gap-2 mb-4 border-b border-rule pb-3">
            <span class={`w-2 h-2 rounded-full ${style.dot}`}></span>
            <h2 class={`font-mono text-xs uppercase tracking-wider ${style.header}`}>
              {col.label}
            </h2>
            <span class="ml-auto text-xs font-mono text-ink-faint border border-rule px-2 py-0.5 rounded">
              {col.items.length}
            </span>
          </div>

          <div class="flex flex-col gap-3">
            {col.items.map(item => (
              <div class="rounded-md border border-rule bg-surface p-4">
                <div class="flex items-start justify-between gap-2 mb-2">
                  <p class="text-sm text-ink leading-snug">{item.title}</p>
                  <span class={`shrink-0 font-mono text-[0.65rem] uppercase tracking-wider px-1.5 py-0.5 rounded border ${typeColors[item.type] ?? typeColors['infra']}`}>
                    {item.type}
                  </span>
                </div>
                <p class="text-xs text-ink-mute leading-relaxed mb-2">{item.description}</p>
                {'eta' in item && (
                  <p class="text-xs font-mono text-ink-faint">ETA: {item.eta}</p>
                )}
                {'date' in item && (
                  <p class="text-xs font-mono text-accent-2">完成于 {item.date}</p>
                )}
              </div>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</BaseLayout>
