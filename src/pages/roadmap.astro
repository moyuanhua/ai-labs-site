---
import BaseLayout from '../layouts/BaseLayout.astro';
import roadmap from '../data/roadmap.json';

const typeColors: Record<string, string> = {
  feature: 'bg-indigo-900/50 text-indigo-400 border-indigo-800',
  content: 'bg-blue-900/50 text-blue-400 border-blue-800',
  infra:   'bg-slate-800 text-slate-400 border-slate-700',
};

const colStyles: Record<string, { header: string; dot: string }> = {
  planned:     { header: 'text-slate-400', dot: 'bg-slate-500' },
  'in-progress':{ header: 'text-yellow-400', dot: 'bg-yellow-400' },
  done:        { header: 'text-emerald-400', dot: 'bg-emerald-400' },
};
---

<BaseLayout title="Roadmap — ai-sites" description="我们正在做什么，打算做什么">
  <div class="mb-10">
    <h1 class="text-3xl font-bold text-white mb-2">Roadmap</h1>
    <p class="text-slate-400">正在做什么，计划做什么，已经完成了什么。</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    {roadmap.columns.map(col => {
      const style = colStyles[col.id] ?? colStyles['planned'];
      return (
        <div>
          <div class="flex items-center gap-2 mb-4">
            <span class={`w-2 h-2 rounded-full ${style.dot}`}></span>
            <h2 class={`font-semibold text-sm uppercase tracking-wider ${style.header}`}>
              {col.label}
            </h2>
            <span class="ml-auto text-xs text-slate-600 bg-slate-800 px-2 py-0.5 rounded-full">
              {col.items.length}
            </span>
          </div>

          <div class="flex flex-col gap-3">
            {col.items.map(item => (
              <div class="rounded-xl border border-slate-800 bg-slate-900 p-4">
                <div class="flex items-start justify-between gap-2 mb-1.5">
                  <p class="text-sm font-medium text-white leading-snug">{item.title}</p>
                  <span class={`shrink-0 text-xs px-1.5 py-0.5 rounded border ${typeColors[item.type] ?? typeColors['infra']}`}>
                    {item.type}
                  </span>
                </div>
                <p class="text-xs text-slate-500 leading-relaxed mb-2">{item.description}</p>
                {'eta' in item && (
                  <p class="text-xs text-slate-600">ETA: {item.eta}</p>
                )}
                {'date' in item && (
                  <p class="text-xs text-emerald-700">完成于 {item.date}</p>
                )}
              </div>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</BaseLayout>
