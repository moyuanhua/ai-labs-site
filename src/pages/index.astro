---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentCard from '../components/ContentCard.astro';
import { getCollection } from 'astro:content';

const BASE = import.meta.env.BASE_URL;

const allPosts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const allDemos = (await getCollection('demos'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const allProducts = (await getCollection('products'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const statusBadge = (status: string) => {
  if (status === 'live') return { label: 'Live', color: 'green' as const };
  if (status === 'beta') return { label: 'Beta', color: 'yellow' as const };
  return { label: 'Coming Soon', color: 'slate' as const };
};
---

<BaseLayout title="ai-labs" description="HTML-first content publishing — blog, demos, products">
  <section class="py-16 text-center">
    <h1 class="text-4xl font-bold text-white mb-4 tracking-tight">
      HTML-First Publishing
    </h1>
    <p class="text-slate-400 text-lg max-w-xl mx-auto leading-relaxed">
      每一篇内容都是一个独立的 HTML 页面——比 Markdown 更丰富，AI 生成更容易，交互更自由。
    </p>
    <div class="flex items-center justify-center gap-3 mt-8">
      <a href={`${BASE}blog`} class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white rounded-lg text-sm font-medium transition-colors">
        阅读博客
      </a>
      <a href={`${BASE}roadmap`} class="px-5 py-2.5 border border-slate-700 hover:border-slate-500 text-slate-300 hover:text-white rounded-lg text-sm font-medium transition-colors">
        查看 Roadmap
      </a>
    </div>
  </section>

  {allPosts.length > 0 && (
    <section class="mb-14">
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-xl font-semibold text-white">最新文章</h2>
        <a href={`${BASE}blog`} class="text-sm text-indigo-400 hover:text-indigo-300 transition-colors">全部 →</a>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {allPosts.map(post => (
          <ContentCard
            href={`${BASE}blog/${post.id}`}
            title={post.data.title}
            date={post.data.date}
            description={post.data.description}
            tags={post.data.tags}
          />
        ))}
      </div>
    </section>
  )}

  {allDemos.length > 0 && (
    <section class="mb-14">
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-xl font-semibold text-white">交互 Demo</h2>
        <a href={`${BASE}demos`} class="text-sm text-indigo-400 hover:text-indigo-300 transition-colors">全部 →</a>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {allDemos.map(demo => (
          <ContentCard
            href={`${BASE}demos/${demo.id}`}
            title={demo.data.title}
            date={demo.data.date}
            description={demo.data.description}
            tags={demo.data.tags}
          />
        ))}
      </div>
    </section>
  )}

  {allProducts.length > 0 && (
    <section class="mb-14">
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-xl font-semibold text-white">产品</h2>
        <a href={`${BASE}products`} class="text-sm text-indigo-400 hover:text-indigo-300 transition-colors">全部 →</a>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {allProducts.map(product => (
          <ContentCard
            href={`${BASE}products/${product.id}`}
            title={product.data.title}
            date={product.data.date}
            description={product.data.description}
            badge={statusBadge(product.data.status)}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
