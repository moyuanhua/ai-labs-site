---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentCard from '../components/ContentCard.astro';
import AmbientCanvas from '../components/AmbientCanvas.astro';
import { getCollection } from 'astro:content';

const BASE = import.meta.env.BASE_URL;

const allPosts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const allDemos = (await getCollection('demos'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const allProducts = (await getCollection('products'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const statusBadge = (status: string) => {
  if (status === 'live') return { label: 'Live', color: 'green' as const };
  if (status === 'beta') return { label: 'Beta', color: 'yellow' as const };
  return { label: 'Coming Soon', color: 'slate' as const };
};
---

<BaseLayout title="ai-labs" description="HTML-first content publishing — blog, demos, products">
  <AmbientCanvas />

  <section class="py-20 text-center max-w-3xl mx-auto">
    <p class="text-xs uppercase tracking-wider font-mono text-ink-mute mb-4">个人站 · HTML-FIRST</p>
    <h1 class="font-serif text-5xl sm:text-6xl font-medium text-ink mb-6 tracking-tight leading-[1.05]">
      moyuanhua
    </h1>
    <p class="font-mono text-ink-mute text-base max-w-xl mx-auto leading-relaxed">
      HTML-first publishing. Interactive demos. Building in public.
    </p>
    <div class="flex items-center justify-center gap-3 mt-10 flex-wrap">
      <a href={`${BASE}blog`} class="px-5 py-2.5 bg-accent text-bg hover:bg-accent/90 rounded font-mono text-sm font-medium transition-colors">
        阅读博客
      </a>
      <a href={`${BASE}roadmap`} class="px-5 py-2.5 border border-rule text-ink hover:border-ink-mute rounded font-mono text-sm transition-colors">
        查看 Roadmap
      </a>
    </div>
  </section>

  {allPosts.length > 0 && (
    <section class="mb-16">
      <header class="mb-6 border-b border-rule pb-4">
        <div class="flex items-end justify-between gap-4 flex-wrap">
          <div>
            <p class="text-xs uppercase tracking-wider font-mono text-ink-mute mb-1.5">blog · {String(allPosts.length).padStart(2, '0')}</p>
            <h2 class="font-serif text-2xl text-ink">最新文章</h2>
          </div>
          <a href={`${BASE}blog`} class="font-mono text-sm text-accent hover:text-accent/80 transition-colors">全部 →</a>
        </div>
      </header>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {allPosts.map(post => (
          <ContentCard
            href={`${BASE}blog/${post.id}`}
            title={post.data.title}
            date={post.data.date}
            description={post.data.description}
            tags={post.data.tags}
          />
        ))}
      </div>
    </section>
  )}

  {allDemos.length > 0 && (
    <section class="mb-16">
      <header class="mb-6 border-b border-rule pb-4">
        <div class="flex items-end justify-between gap-4 flex-wrap">
          <div>
            <p class="text-xs uppercase tracking-wider font-mono text-ink-mute mb-1.5">demos · {String(allDemos.length).padStart(2, '0')}</p>
            <h2 class="font-serif text-2xl text-ink">交互 Demo</h2>
          </div>
          <a href={`${BASE}demos`} class="font-mono text-sm text-accent hover:text-accent/80 transition-colors">全部 →</a>
        </div>
      </header>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {allDemos.map(demo => (
          <ContentCard
            href={`${BASE}demos/${demo.id}`}
            title={demo.data.title}
            date={demo.data.date}
            description={demo.data.description}
            tags={demo.data.tags}
          />
        ))}
      </div>
    </section>
  )}

  {allProducts.length > 0 && (
    <section class="mb-16">
      <header class="mb-6 border-b border-rule pb-4">
        <div class="flex items-end justify-between gap-4 flex-wrap">
          <div>
            <p class="text-xs uppercase tracking-wider font-mono text-ink-mute mb-1.5">products · {String(allProducts.length).padStart(2, '0')}</p>
            <h2 class="font-serif text-2xl text-ink">产品</h2>
          </div>
          <a href={`${BASE}products`} class="font-mono text-sm text-accent hover:text-accent/80 transition-colors">全部 →</a>
        </div>
      </header>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {allProducts.map(product => (
          <ContentCard
            href={`${BASE}products/${product.id}`}
            title={product.data.title}
            date={product.data.date}
            description={product.data.description}
            badge={statusBadge(product.data.status)}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
