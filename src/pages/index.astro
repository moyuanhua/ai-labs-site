---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentCard from '../components/ContentCard.astro';
import ChatLayer from '../components/ChatLayer.astro';
import { getCollection } from 'astro:content';

const BASE = import.meta.env.BASE_URL;

const allPosts = (await getCollection('posts'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const typeBadge = {
  blog:    { label: 'Blog',    color: 'slate'  as const },
  demo:    { label: 'Demo',    color: 'green'  as const },
  product: { label: 'Product', color: 'yellow' as const },
};
---

<BaseLayout title="ai-labs" description="moyuanhua — personal portfolio of writing, demos, and AI experiments" chatVariant="hero">

  <ChatLayer variant="hero" />

  <section class="mt-20 mb-8 text-center">
    <p class="text-text-muted text-sm font-body">— or browse the content —</p>
  </section>

  {allPosts.length > 0 && (
    <section class="mb-16">
      <header class="mb-6 flex items-end justify-between gap-4 flex-wrap">
        <div>
          <p class="text-xs uppercase tracking-widest font-body font-medium text-text-muted mb-2">
            posts · {String(allPosts.length).padStart(2, '0')}
          </p>
          <h2 class="font-heading text-2xl sm:text-3xl font-semibold text-text">最新内容</h2>
        </div>
        <a
          href={`${BASE}posts`}
          class="font-body text-sm font-medium text-accent hover:text-accent-2 transition-colors duration-200 cursor-pointer"
        >
          全部 →
        </a>
      </header>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {allPosts.map(post => (
          <ContentCard
            href={`${BASE}posts/${post.id}`}
            title={post.data.title}
            date={post.data.date}
            description={post.data.description}
            tags={post.data.tags}
            badge={typeBadge[post.data.type]}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
