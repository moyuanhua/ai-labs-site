---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).filter(p => !p.data.draft);
  return posts.map(post => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const BASE = import.meta.env.BASE_URL;

const statusConfig = {
  live:          { label: '已上线', cls: 'bg-emerald-500/15 text-emerald-400 border-emerald-500/25' },
  beta:          { label: '测试中', cls: 'bg-amber-500/15   text-amber-400   border-amber-500/25' },
  'coming-soon': { label: '即将',   cls: 'bg-white/10       text-white/50    border-white/15' },
};
const statusBadge = post.data.status ? statusConfig[post.data.status] : null;
---

<BaseLayout title={`${post.data.title} — ai-labs`} description={post.data.description}>
  <article class="scroll-reveal max-w-3xl mx-auto py-12 px-6 sm:px-10 lg:px-16 xl:px-24">
    <a
      href={`${BASE}posts`}
      class="font-body text-sm text-white/50 hover:text-white transition-colors duration-200 cursor-pointer"
    >
      ← 内容
    </a>

    <header class="mt-8 mb-12">
      <div class="flex items-start gap-4 flex-wrap">
        <h1 class="font-heading text-4xl font-normal text-white leading-tight tracking-tight flex-1">
          {post.data.title}
        </h1>
        {statusBadge && (
          <span class={`shrink-0 text-sm font-body font-medium px-3 py-1 rounded-full border ${statusBadge.cls}`}>
            {statusBadge.label}
          </span>
        )}
      </div>
      <time
        datetime={post.data.date.toISOString()}
        class="font-body text-sm text-white/40 block mt-4"
      >
        {post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-4">
          {post.data.tags.map(tag => (
            <span class="inline-flex items-center text-xs font-medium font-body text-indigo-400 bg-indigo-500/10 border border-indigo-500/20 px-2.5 py-1 rounded-full">
              {tag}
            </span>
          ))}
        </div>
      )}

      {(post.data.url || post.data.github) && (
        <div class="flex gap-3 mt-6 flex-wrap">
          {post.data.url && (
            <a
              href={post.data.url}
              target="_blank"
              rel="noopener noreferrer"
              class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white rounded-full font-body font-semibold text-sm transition-colors duration-200 cursor-pointer"
            >
              访问产品 ↗
            </a>
          )}
          {post.data.github && (
            <a
              href={post.data.github}
              target="_blank"
              rel="noopener noreferrer"
              class="px-5 py-2.5 border border-white/15 text-white/60 hover:text-white hover:border-white/30 rounded-full font-body font-medium text-sm transition-colors duration-200 cursor-pointer"
            >
              GitHub ↗
            </a>
          )}
        </div>
      )}
    </header>

    <div class="prose-content">
      <Content />
    </div>
  </article>
</BaseLayout>
