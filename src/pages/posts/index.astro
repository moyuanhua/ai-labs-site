---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import { getCollection } from 'astro:content';

const BASE = import.meta.env.BASE_URL;
const posts = (await getCollection('posts'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const typeBadge = {
  blog:    { label: '博客',  color: 'slate'  as const },
  demo:    { label: 'Demo', color: 'green'  as const },
  product: { label: '产品',  color: 'yellow' as const },
};
---

<BaseLayout title="内容 — ai-labs" description="所有内容：博客、Demo、产品">

  <header class="pt-16 pb-12 text-center">
    <p class="text-xs uppercase tracking-widest font-body font-medium text-text-muted mb-4">
      内容 · {String(posts.length).padStart(2, '0')}
    </p>
    <h1 class="font-heading text-4xl font-semibold text-text mb-4 tracking-tight">
      内容
    </h1>
    <p class="font-body text-base sm:text-lg text-text-muted max-w-xl mx-auto leading-relaxed">
      博客、Demo、产品——所有内容都在这里。
    </p>
  </header>

  <section>
    {posts.length === 0 ? (
      <p class="font-body text-text-muted text-center py-20">— 暂无内容，敬请期待 —</p>
    ) : (
      <div class="grid gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map(post => (
          <ContentCard
            href={`${BASE}posts/${post.id}`}
            title={post.data.title}
            date={post.data.date}
            description={post.data.description}
            tags={post.data.tags}
            badge={typeBadge[post.data.type]}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>
