---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import AmbientCanvas from '../../components/AmbientCanvas.astro';
import { getCollection } from 'astro:content';

const BASE = import.meta.env.BASE_URL;
const products = (await getCollection('products'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const badgeConfig = {
  live:          { label: 'Live',         color: 'green'  as const },
  beta:          { label: 'Beta',         color: 'yellow' as const },
  'coming-soon': { label: 'Coming Soon',  color: 'slate'  as const },
};
---

<BaseLayout title="Products — ai-labs" description="产品展示">
  <AmbientCanvas />

  <header class="mb-12">
    <p class="text-xs uppercase tracking-wider font-mono text-ink-mute mb-3">products · index</p>
    <h1 class="font-serif text-4xl sm:text-5xl text-ink mb-3 tracking-tight">Products</h1>
    <p class="font-mono text-ink-mute leading-relaxed">我们正在构建的产品。</p>
  </header>

  {products.length === 0 ? (
    <p class="font-mono text-ink-faint text-center py-20">— 暂无产品，敬请期待 —</p>
  ) : (
    <div class="grid gap-4 sm:grid-cols-2">
      {products.map(product => (
        <ContentCard
          href={`${BASE}products/${product.id}`}
          title={product.data.title}
          date={product.data.date}
          description={product.data.description}
          badge={badgeConfig[product.data.status]}
        />
      ))}
    </div>
  )}
</BaseLayout>
