---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const products = (await getCollection('posts')).filter(p => p.data.type === 'product');
  return products
    .filter(p => !p.data.draft)
    .map(product => ({ params: { slug: product.id }, props: { product } }));
}

const { product } = Astro.props;
const { Content } = await render(product);
const BASE = import.meta.env.BASE_URL;

const statusConfig = {
  live:          { label: 'Live',        cls: 'bg-emerald-100 text-emerald-700 border-emerald-200' },
  beta:          { label: 'Beta',        cls: 'bg-amber-100   text-amber-700   border-amber-200' },
  'coming-soon': { label: 'Coming Soon', cls: 'bg-zinc-100    text-zinc-500    border-zinc-200' },
};
const badge = statusConfig[product.data.status];
---

<BaseLayout title={`${product.data.title} — ai-labs`} description={product.data.description}>
  <article class="max-w-3xl mx-auto py-12">
    <a
      href={`${BASE}products`}
      class="font-body text-sm text-text-muted hover:text-accent transition-colors duration-200 cursor-pointer"
    >
      ← Products
    </a>

    <header class="mt-8 mb-12">
      <div class="flex items-start gap-4 flex-wrap">
        <h1 class="font-heading text-4xl font-semibold text-text leading-tight tracking-tight flex-1">
          {product.data.title}
        </h1>
        <span class={`shrink-0 text-sm font-body font-medium px-3 py-1 rounded-full border ${badge.cls}`}>
          {badge.label}
        </span>
      </div>
      <p class="font-body text-base text-text-muted mt-4 leading-relaxed">
        {product.data.description}
      </p>

      {(product.data.url || product.data.github) && (
        <div class="flex gap-3 mt-6 flex-wrap">
          {product.data.url && (
            <a
              href={product.data.url}
              target="_blank"
              rel="noopener noreferrer"
              class="px-5 py-2.5 bg-accent text-white hover:bg-accent-2 rounded-full font-body font-semibold text-sm transition-colors duration-200 cursor-pointer"
            >
              访问产品 ↗
            </a>
          )}
          {product.data.github && (
            <a
              href={product.data.github}
              target="_blank"
              rel="noopener noreferrer"
              class="px-5 py-2.5 border border-border text-text-muted hover:text-text hover:border-text-muted rounded-full font-body font-medium text-sm transition-colors duration-200 cursor-pointer"
            >
              GitHub ↗
            </a>
          )}
        </div>
      )}
    </header>

    <div class="prose-content">
      <Content />
    </div>
  </article>
</BaseLayout>
