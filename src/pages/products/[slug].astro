---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AmbientCanvas from '../../components/AmbientCanvas.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products
    .filter(p => !p.data.draft)
    .map(product => ({ params: { slug: product.id }, props: { product } }));
}

const { product } = Astro.props;
const { Content } = await render(product);
const BASE = import.meta.env.BASE_URL;

const statusConfig = {
  live:          { label: 'Live',         cls: 'bg-teal-900/40  text-teal-300  border-teal-800' },
  beta:          { label: 'Beta',         cls: 'bg-amber-900/40 text-amber-300 border-amber-800' },
  'coming-soon': { label: 'Coming Soon',  cls: 'bg-surface      text-ink-mute  border-rule' },
};
const badge = statusConfig[product.data.status];
---

<BaseLayout title={`${product.data.title} — ai-labs`} description={product.data.description}>
  <AmbientCanvas />

  <article class="max-w-2xl mx-auto">
    <a href={`${BASE}products`} class="font-mono text-sm text-ink-mute hover:text-accent transition-colors">← Products</a>

    <header class="mt-8 mb-10">
      <div class="flex items-start gap-4 flex-wrap">
        <h1 class="font-serif text-3xl sm:text-4xl text-ink leading-tight tracking-tight flex-1">{product.data.title}</h1>
        <span class={`text-sm font-mono px-3 py-1 rounded-full border ${badge.cls}`}>{badge.label}</span>
      </div>
      <p class="font-mono text-ink-mute mt-3 leading-relaxed">{product.data.description}</p>

      <div class="flex gap-3 mt-6 flex-wrap">
        {product.data.url && (
          <a href={product.data.url} target="_blank" rel="noopener noreferrer"
             class="px-4 py-2 bg-accent text-bg hover:bg-accent/90 rounded font-mono text-sm font-medium transition-colors">
            访问产品 ↗
          </a>
        )}
        {product.data.github && (
          <a href={product.data.github} target="_blank" rel="noopener noreferrer"
             class="px-4 py-2 border border-rule text-ink hover:border-ink-mute rounded font-mono text-sm transition-colors">
            GitHub ↗
          </a>
        )}
      </div>
    </header>

    <div class="prose-content">
      <Content />
    </div>
  </article>
</BaseLayout>
