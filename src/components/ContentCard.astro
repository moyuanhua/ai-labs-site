---
interface Props {
  href: string;
  title: string;
  date?: Date;
  description: string;
  tags?: string[];
  badge?: { label: string; color: 'green' | 'yellow' | 'slate' };
}
const { href, title, date, description, tags = [], badge } = Astro.props;

const badgeColors = {
  green:  'bg-teal-900/40  text-teal-300  border-teal-800',
  yellow: 'bg-amber-900/40 text-amber-300 border-amber-800',
  slate:  'bg-surface      text-ink-mute  border-rule',
};
---

<a
  href={href}
  class="group block rounded-md border border-rule bg-surface p-5 hover:bg-surface-2 hover:border-ink-faint transition-colors"
>
  <div class="flex items-start justify-between gap-3 mb-2">
    <h3 class="font-medium text-ink group-hover:text-accent transition-colors leading-snug">
      {title}
    </h3>
    {badge && (
      <span class={`shrink-0 text-xs px-2 py-0.5 rounded-full border ${badgeColors[badge.color]}`}>
        {badge.label}
      </span>
    )}
  </div>

  {date && (
    <p class="text-xs font-mono text-ink-mute mb-2">
      {date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
    </p>
  )}

  <p class="text-sm text-ink-mute leading-relaxed mb-3">{description}</p>

  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5">
      {tags.map(tag => (
        <span class="text-xs font-mono text-ink-faint bg-surface px-2 py-0.5 rounded">
          {tag}
        </span>
      ))}
    </div>
  )}
</a>
