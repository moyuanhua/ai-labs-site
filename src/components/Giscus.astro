---
/**
 * Giscus comment component.
 * Configure repo / repoId / category / categoryId after enabling Giscus
 * on your GitHub repository at https://giscus.app
 */
---

<section class="giscus-wrapper">
  <script
    src="https://giscus.app/client.js"
    data-repo="moyuanhua/ai-labs-site"
    data-repo-id=""
    data-category="Announcements"
    data-category-id=""
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="top"
    data-theme="light"
    data-lang="zh-CN"
    crossorigin="anonymous"
    async
  ></script>
</section>

<style>
  .giscus-wrapper {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid #e0e0e0;
  }
</style>
