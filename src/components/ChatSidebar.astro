---
const BASE = import.meta.env.BASE_URL;
---

{/* Desktop sidebar — persistent right panel on xl+ (>=1280px).
    On <1280px (mobile + tablet), a FAB + bottom drawer is used instead.
    The wrapper in BaseLayout adds xl:pr-[360px] so content reflows left. */}
<aside
  id="chat-sidebar-desktop"
  class="hidden xl:flex fixed right-0 top-16 bottom-0 w-[340px] bg-surface border-l border-border z-30 flex-col"
  aria-label="Chat with moyuanhua's AI"
>
  <header class="h-14 border-b border-border px-4 flex items-center justify-between shrink-0">
    <span class="font-heading font-semibold text-text">Talk to me</span>
    <span class="bg-accent/10 text-accent text-xs px-2 py-0.5 rounded-full border border-accent/30 uppercase tracking-wider font-body font-medium">
      soon
    </span>
  </header>

  <div class="flex-1 overflow-y-auto p-4 space-y-3">
    <div class="bg-surface-2 rounded-2xl rounded-tl-sm p-3 text-sm text-text font-body leading-relaxed">
      Hi, I'm an AI trained on moyuanhua's site and resume. Chat is coming soon — you'll be able to ask me anything about his work, demos, and writing.
    </div>
    <p class="text-xs text-text-faint font-body">— coming soon</p>
  </div>

  <div class="border-t border-border p-3 shrink-0">
    <input
      type="text"
      disabled
      placeholder="等上线后可以问我任何问题…"
      class="w-full bg-surface-2 border border-border rounded-lg px-3 py-2 text-sm text-text-muted cursor-not-allowed placeholder:text-text-faint font-body focus:outline-none"
    />
    <button
      type="button"
      disabled
      class="mt-2 w-full bg-accent/50 text-white/70 rounded-lg py-2 text-sm font-medium cursor-not-allowed font-body"
    >
      发送 (即将上线)
    </button>
  </div>
</aside>

{/* Mobile + tablet FAB — visible below xl (1280px) */}
<button
  id="chat-fab"
  type="button"
  aria-label="Open chat"
  class="xl:hidden fixed bottom-6 right-6 z-30 w-14 h-14 rounded-full bg-accent text-white shadow-lg flex items-center justify-center cursor-pointer hover:bg-accent-2 transition-colors duration-200"
>
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
  </svg>
</button>

{/* Mobile + tablet drawer backdrop */}
<div
  id="chat-backdrop"
  class="xl:hidden hidden fixed inset-0 bg-black/30 z-40"
  aria-hidden="true"
>
</div>

{/* Mobile + tablet bottom drawer — covers bottom half of screen */}
<div
  id="chat-drawer"
  role="dialog"
  aria-label="Chat with moyuanhua's AI"
  class="xl:hidden hidden fixed inset-x-0 bottom-0 top-1/2 z-50 bg-surface border-t border-border rounded-t-2xl flex flex-col"
>
  <div class="mx-auto mt-2 w-10 h-1 rounded-full bg-text-faint shrink-0 cursor-pointer" id="chat-drawer-handle" aria-hidden="true"></div>

  <header class="h-14 border-b border-border px-4 flex items-center justify-between shrink-0">
    <span class="font-heading font-semibold text-text">Talk to me</span>
    <span class="bg-accent/10 text-accent text-xs px-2 py-0.5 rounded-full border border-accent/30 uppercase tracking-wider font-body font-medium">
      soon
    </span>
  </header>

  <div class="flex-1 overflow-y-auto p-4 space-y-3">
    <div class="bg-surface-2 rounded-2xl rounded-tl-sm p-3 text-sm text-text font-body leading-relaxed">
      Hi, I'm an AI trained on moyuanhua's site and resume. Chat is coming soon — you'll be able to ask me anything about his work, demos, and writing.
    </div>
    <p class="text-xs text-text-faint font-body">— coming soon</p>
  </div>

  <div class="border-t border-border p-3 shrink-0">
    <input
      id="chat-drawer-input"
      type="text"
      disabled
      placeholder="等上线后可以问我任何问题…"
      class="w-full bg-surface-2 border border-border rounded-lg px-3 py-2 text-sm text-text-muted cursor-not-allowed placeholder:text-text-faint font-body focus:outline-none"
    />
    <button
      type="button"
      disabled
      class="mt-2 w-full bg-accent/50 text-white/70 rounded-lg py-2 text-sm font-medium cursor-not-allowed font-body"
    >
      发送 (即将上线)
    </button>
  </div>
</div>

<script>
  const fab = document.getElementById('chat-fab');
  const drawer = document.getElementById('chat-drawer');
  const backdrop = document.getElementById('chat-backdrop');
  const handle = document.getElementById('chat-drawer-handle');
  const input = document.getElementById('chat-drawer-input');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  let lastFocused: HTMLElement | null = null;

  function openDrawer() {
    if (!fab || !drawer || !backdrop) return;
    lastFocused = document.activeElement as HTMLElement;
    drawer.classList.remove('hidden');
    backdrop.classList.remove('hidden');
    if (!reduceMotion) {
      drawer.style.transform = 'translateY(100%)';
      drawer.style.transition = 'transform 300ms ease-out';
      requestAnimationFrame(() => {
        drawer.style.transform = 'translateY(0)';
      });
    }
    if (input) input.focus();
  }

  function closeDrawer() {
    if (!fab || !drawer || !backdrop) return;
    if (!reduceMotion && drawer.style.transform !== '') {
      drawer.style.transform = 'translateY(100%)';
      setTimeout(() => {
        drawer.classList.add('hidden');
        drawer.style.transform = '';
        drawer.style.transition = '';
      }, 300);
    } else {
      drawer.classList.add('hidden');
    }
    backdrop.classList.add('hidden');
    if (lastFocused) lastFocused.focus();
    else fab.focus();
  }

  fab?.addEventListener('click', openDrawer);
  backdrop?.addEventListener('click', closeDrawer);
  handle?.addEventListener('click', closeDrawer);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer && !drawer.classList.contains('hidden')) {
      closeDrawer();
    }
  });
</script>
