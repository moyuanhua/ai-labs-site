---
interface Props {
  intensity?: 'ambient' | 'featured';
}
const { intensity = 'ambient' } = Astro.props;
const isFeatured = intensity === 'featured';
---

<canvas
  class:list={['ambient-canvas', isFeatured && 'ambient-canvas--featured']}
  data-intensity={intensity}
  aria-hidden="true"
></canvas>

<style>
  .ambient-canvas {
    position: fixed;
    right: 1.5rem;
    bottom: 1.5rem;
    width: 320px;
    height: 200px;
    pointer-events: none;
    z-index: 0;
    opacity: 0.9;
  }

  @media (max-width: 640px) {
    .ambient-canvas {
      right: 0.75rem;
      bottom: 0.75rem;
      width: 200px;
      height: 140px;
      opacity: 0.7;
    }
  }

  @media print {
    .ambient-canvas {
      display: none;
    }
  }

  /* Static dotted fallback for prefers-reduced-motion.
     The script never runs the physics loop in this state; the canvas
     stays transparent and the element's CSS background shows through. */
  .ambient-canvas.reduced-motion {
    background-image: radial-gradient(
      circle,
      var(--color-accent) 1px,
      transparent 1.2px
    );
    background-size: 14px 14px;
    background-position: center;
    opacity: 0.28;
  }

  .ambient-canvas--featured.reduced-motion {
    background-image: radial-gradient(
      circle,
      var(--color-accent) 1.2px,
      var(--color-accent-2) 1.2px,
      transparent 1.5px
    );
    background-size: 11px 11px;
    opacity: 0.45;
  }
</style>

<script>
  type Particle = {
    x: number;
    y: number;
    vx: number;
    vy: number;
    size: number;
    color: string;
    alpha: number;
  };

  function init() {
    const canvas = document.querySelector<HTMLCanvasElement>('.ambient-canvas');
    if (!canvas) return;

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reducedMotion) {
      canvas.classList.add('reduced-motion');
      return;
    }

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const isFeatured = canvas.classList.contains('ambient-canvas--featured');
    const COUNT = isFeatured ? 140 : 80;
    const MAX_ALPHA = isFeatured ? 0.8 : 0.6;
    const MIN_ALPHA = isFeatured ? 0.5 : 0.3;
    const DRIFT = isFeatured ? 0.55 : 0.4;

    const styles = getComputedStyle(document.documentElement);
    const accentColor = styles.getPropertyValue('--color-accent').trim() || '#E89B4C';
    const accent2Color = styles.getPropertyValue('--color-accent-2').trim() || '#5BA8A0';

    const dpr = window.devicePixelRatio || 1;
    const rect = canvas.getBoundingClientRect();
    canvas.width = Math.max(1, Math.round(rect.width * dpr));
    canvas.height = Math.max(1, Math.round(rect.height * dpr));
    ctx.scale(dpr, dpr);
    const W = rect.width;
    const H = rect.height;
    const cx = W / 2;
    const cy = H / 2;

    let mouseX = -9999;
    let mouseY = -9999;
    let mouseActive = false;
    let lastMove = 0;

    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      mouseActive = true;
      lastMove = performance.now();
    });
    document.addEventListener('mouseleave', () => {
      mouseActive = false;
    });

    const particles: Particle[] = [];
    for (let i = 0; i < COUNT; i++) {
      particles.push({
        x: Math.random() * W,
        y: Math.random() * H,
        vx: (Math.random() - 0.5) * DRIFT,
        vy: (Math.random() - 0.5) * DRIFT,
        size: Math.random() * 1.4 + 0.6,
        color: Math.random() < 0.7 ? accentColor : accent2Color,
        alpha: MIN_ALPHA + Math.random() * (MAX_ALPHA - MIN_ALPHA),
      });
    }

    function step() {
      // Fade out trails using the design-system background color.
      ctx.fillStyle = 'rgba(15, 17, 21, 0.22)';
      ctx.fillRect(0, 0, W, H);

      // Decay mouse influence 1.5s after the last move.
      const recentMove = performance.now() - lastMove < 1500;

      for (const p of particles) {
        // Brownian motion — small random kick each frame.
        p.vx += (Math.random() - 0.5) * 0.08;
        p.vy += (Math.random() - 0.5) * 0.08;

        // Tiny gravity toward canvas center.
        p.vx += (cx - p.x) * 0.0003;
        p.vy += (cy - p.y) * 0.0003;

        // Gentle document-wide pull toward cursor.
        // Long range, weak force — this is ambient, not an interactive toy.
        if (mouseActive && recentMove) {
          const mdx = mouseX - p.x;
          const mdy = mouseY - p.y;
          const mdist = Math.sqrt(mdx * mdx + mdy * mdy) || 1;
          const force = Math.min(30 / (mdist + 100), 0.05);
          p.vx += (mdx / mdist) * force;
          p.vy += (mdy / mdist) * force;
        }

        // Damping so velocities don't run away.
        p.vx *= 0.985;
        p.vy *= 0.985;

        p.x += p.vx;
        p.y += p.vy;

        // Wrap around edges so the field feels endless.
        if (p.x < -10) p.x = W + 10;
        else if (p.x > W + 10) p.x = -10;
        if (p.y < -10) p.y = H + 10;
        else if (p.y > H + 10) p.y = -10;

        ctx.globalAlpha = p.alpha;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = p.color;
        ctx.fill();
      }
      ctx.globalAlpha = 1;

      requestAnimationFrame(step);
    }
    step();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
