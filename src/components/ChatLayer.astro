---
interface Props {
  variant: 'hero' | 'dock' | 'fullscreen';
}
const { variant } = Astro.props;
const BASE = import.meta.env.BASE_URL;
---

{variant === 'hero' && (
  <div
    transition:name="chat-layer"
    class="chat-hero relative flex flex-col h-[calc(100vh-65px)] bg-[#090909] overflow-hidden"
  >
    {/* AI pulse orb — full-area backdrop */}
    <canvas data-chat-orb class="absolute inset-0 w-full h-full pointer-events-none" aria-hidden="true"></canvas>

    {/* Top status bar */}
    <div class="relative z-10 shrink-0 px-6 sm:px-10 lg:px-16 xl:px-24 pt-6 pb-4 flex items-center justify-between border-b border-white/8">
      <div class="flex items-center gap-3">
        <span class="font-heading text-2xl sm:text-3xl text-white font-semibold tracking-tight">moyuanhua</span>
      </div>
      <div class="flex items-center gap-2 text-sm text-white/50">
        <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
        <span>在线</span>
      </div>
    </div>

    {/* Greeting + messages */}
    <div class="relative z-10 flex-1 flex flex-col justify-center w-full px-6 sm:px-10 lg:px-16 xl:px-24 py-8">
      <div class="mb-6">
        <p class="font-heading text-xl sm:text-2xl text-white font-medium mb-2">
          你好，我是 moyuanhua 的 AI
        </p>
        <p class="font-body text-sm sm:text-base text-white/50 leading-relaxed max-w-lg">
          问我关于我的工作、demo 或写作。我了解这个网站上的所有内容。
        </p>
      </div>

      <div data-chat-messages class="flex-1 min-h-[160px] max-h-[40vh] overflow-y-auto space-y-3 pr-2"></div>
    </div>

    {/* Bottom input bar */}
    <div class="relative z-10 shrink-0 border-t border-white/8 bg-[#111]">
      <div class="w-full px-6 sm:px-10 lg:px-16 xl:px-24 py-5 flex gap-3 items-center">
        <div class="relative flex-1">
          <span data-chat-placeholder class="chat-placeholder absolute inset-0 flex items-center pointer-events-none text-white/40 text-sm sm:text-base font-body select-none">
            随便问点什么…<span class="chat-cursor-blink">▌</span>
          </span>
          <input
            data-chat-input
            type="text"
            placeholder=""
            class="relative w-full bg-transparent border-none text-white text-sm sm:text-base font-body focus:outline-none"
          />
        </div>
        <button
          data-chat-send
          type="button"
          class="shrink-0 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg px-5 py-2 transition-colors cursor-pointer"
        >
          发送
        </button>
      </div>
    </div>
  </div>
)}

{variant === 'dock' && (
  <a
    href={`${BASE}chat`}
    transition:name="chat-layer"
    data-chat-dock
    class="chat-dock fixed bottom-6 right-6 z-30 w-14 h-14 rounded-full bg-[#111] border border-white/10 hover:border-indigo-500 flex items-center justify-center cursor-pointer transition-all duration-200"
    aria-label="打开对话"
  >
    <svg
      width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
      stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
      class="text-indigo-600 w-6 h-6" aria-hidden="true"
    >
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
    </svg>
    <span class="absolute top-0 right-0 w-3 h-3 bg-indigo-600 rounded-full chat-dock-dot" style="display:none;"></span>
  </a>
)}

{variant === 'fullscreen' && (
  <div
    transition:name="chat-layer"
    class="chat-fullscreen fixed inset-0 z-50 bg-[#090909] flex flex-col overflow-hidden"
  >
    <div class="relative flex-1 flex flex-col w-full">
      <canvas data-chat-orb class="absolute inset-0 w-full h-full pointer-events-none" aria-hidden="true"></canvas>
      <header class="relative z-10 shrink-0 px-6 sm:px-10 lg:px-16 xl:px-24 pt-6 pb-4 flex items-center justify-between border-b border-white/8">
        <div class="flex items-center gap-3">
          <span class="font-heading text-lg text-white font-medium">moyuanhua 的 AI</span>
          <span class="w-2 h-2 bg-emerald-500 rounded-full" aria-hidden="true"></span>
        </div>
        <div class="flex items-center gap-4">
          <span class="text-sm text-white/50 hidden sm:inline">在线</span>
          <button
            type="button"
            onclick="history.back()"
            class="text-white/40 hover:text-white transition-colors cursor-pointer"
            aria-label="关闭对话"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
            >
              <path d="M18 6L6 18M6 6l12 12" />
            </svg>
          </button>
        </div>
      </header>

      <div class="relative z-10 flex-1 overflow-hidden">
        <div data-chat-messages class="h-full overflow-y-auto px-6 sm:px-10 lg:px-16 xl:px-24 py-6 space-y-4"></div>
      </div>

      <div class="relative z-10 shrink-0 border-t border-white/8 bg-[#111]">
        <div class="px-6 sm:px-10 lg:px-16 xl:px-24 py-5 flex gap-3 items-center">
          <div class="relative flex-1">
            <span data-chat-placeholder class="chat-placeholder absolute inset-0 flex items-center pointer-events-none text-white/40 text-sm sm:text-base font-body select-none">
              随便问点什么…<span class="chat-cursor-blink">▌</span>
            </span>
            <input
              data-chat-input
              type="text"
              placeholder=""
              class="relative w-full bg-transparent border-none text-white text-sm sm:text-base font-body focus:outline-none"
            />
          </div>
          <button
            data-chat-send
            type="button"
            class="shrink-0 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg px-5 py-2 transition-colors cursor-pointer"
          >
            发送
          </button>
        </div>
      </div>
    </div>
  </div>
)}

<script>
  const STORAGE_KEY = 'moyuanhua-chat-history';
  const FAKE_AI_REPLY = "I'm still being trained on moyuanhua's content. Once I'm live, I'll be able to answer questions about the blog, demos, and products. For now, feel free to browse the content on the other pages.";
  const EXAMPLE_CONVERSATION: Array<{ role: 'user' | 'ai'; text: string }> = [
    { role: 'user', text: '你可以做什么？' },
    { role: 'ai', text: '我可以回答关于 moyuanhua 的博客文章、demo 项目和产品的问题。比如你可以问我：\n• 你最近写了什么博客？\n• 有哪些有趣的 demo？\n• 你在做哪些产品？' },
  ];

  type OrbState = 'idle' | 'typing' | 'replying';
  let orbState: OrbState = 'idle';
  let orbCanvases: HTMLCanvasElement[] = [];

  function initOrb() {
    orbCanvases = Array.from(document.querySelectorAll('[data-chat-orb]')) as HTMLCanvasElement[];
    orbCanvases.forEach(canvas => {
      const ctx = canvas.getContext('2d');
      if (!ctx) return;
      let w = canvas.clientWidth;
      let h = canvas.clientHeight;
      const dpr = window.devicePixelRatio || 1;

      function resize() {
        w = canvas.clientWidth;
        h = canvas.clientHeight;
        canvas.width = w * dpr;
        canvas.height = h * dpr;
        ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      }
      resize();

      let time = 0;

      // --- Layer 1: Deep-space starfield (150 stars) ---
      type BgStar = { x: number; y: number; vx: number; vy: number; size: number; alpha: number; twinkle: number; color: string };
      const bgStars: BgStar[] = [];
      for (let i = 0; i < 150; i++) {
        const roll = Math.random();
        const color = roll < 0.7 ? '255, 255, 255' : roll < 0.85 ? '180, 200, 255' : '200, 180, 255';
        bgStars.push({
          x: Math.random() * w,
          y: Math.random() * h,
          vx: (Math.random() - 0.5) * 0.15,
          vy: (Math.random() - 0.5) * 0.15,
          size: Math.random() * 1.5 + 0.3,
          alpha: Math.random() * 0.4 + 0.1,
          twinkle: Math.random() * Math.PI * 2,
          color,
        });
      }

      // Faint nebula clouds for depth
      type Nebula = { x: number; y: number; r: number; color: string };
      const nebulae: Nebula[] = [];
      for (let i = 0; i < 3; i++) {
        const color = Math.random() < 0.5 ? '139, 92, 246' : '99, 102, 241';
        nebulae.push({
          x: Math.random() * w,
          y: Math.random() * h,
          r: Math.min(w, h) * (0.2 + Math.random() * 0.3),
          color,
        });
      }

      // --- Layer 3: Accretion disk rings (8 rings) ---
      const ringCount = 8;
      const ringRadii = [1.5, 2.0, 2.5, 3.2, 3.9, 4.6, 5.0, 5.5];
      const ringRyRatio = [0.3, 0.35, 0.4, 0.5, 0.55, 0.65, 0.7, 0.75];
      const ringRotSpeed = [0.2, -0.15, 0.12, -0.1, 0.08, -0.07, 0.06, -0.05];
      const ringTilt = [0.3, -0.25, 0.2, -0.15, 0.12, -0.1, 0.08, -0.06];
      const ringColors: string[] = [
        'rgba(165, 243, 252, 0.15)',
        'rgba(165, 243, 252, 0.15)',
        'rgba(129, 140, 248, 0.12)',
        'rgba(129, 140, 248, 0.12)',
        'rgba(129, 140, 248, 0.12)',
        'rgba(167, 139, 250, 0.08)',
        'rgba(167, 139, 250, 0.08)',
        'rgba(167, 139, 250, 0.08)',
      ];
      const ringWidths = [1.5, 1.5, 1, 1, 1, 1, 1, 1];

      // --- Layer 4: Accretion disk particles (80) ---
      type DiskParticle = { angle: number; ringIdx: number; speed: number; size: number; opacity: number };
      const diskParticles: DiskParticle[] = [];
      for (let i = 0; i < 80; i++) {
        const ringIdx = i % ringCount;
        const isInner = ringIdx < 2;
        const isMiddle = ringIdx >= 2 && ringIdx < 5;
        diskParticles.push({
          angle: Math.random() * Math.PI * 2,
          ringIdx,
          speed: isInner ? 0.004 + Math.random() * 0.004 : isMiddle ? 0.002 + Math.random() * 0.002 : 0.001 + Math.random() * 0.001,
          size: isInner ? 1.5 + Math.random() * 1.5 : isMiddle ? 1 + Math.random() * 1 : 0.5 + Math.random() * 0.8,
          opacity: isInner ? 0.5 + Math.random() * 0.4 : isMiddle ? 0.3 + Math.random() * 0.3 : 0.15 + Math.random() * 0.2,
        });
      }

      // --- Layer 6: Polar data jets ---
      type JetParticle = { x: number; y: number; vx: number; vy: number; life: number; maxLife: number; size: number; prevX: number; prevY: number };
      const jets: JetParticle[] = [];
      const jetAxisAngle = -Math.PI / 2 + 0.3;
      let jetSpawnAccum = 0;

      // --- Layer 7: Shockwaves ---
      type Shockwave = { r: number; alpha: number };
      const shockwaves: Shockwave[] = [];
      let lastShockwaveTime = 0;

      function draw() {
        ctx!.clearRect(0, 0, w, h);
        time += 0.016;

        const cx = w * 0.65;
        const cy = h * 0.5;
        const baseR = Math.min(w, h) * 0.15;

        const breatheSpeed = orbState === 'idle' ? 0.5 : orbState === 'typing' ? 1.5 : 3.0;
        const breatheAmp = orbState === 'idle' ? 0.03 : orbState === 'typing' ? 0.08 : 0.15;
        const breathe = 1 + Math.sin(time * breatheSpeed) * breatheAmp;
        const r = Math.max(1, baseR * breathe);

        const glowAlpha = orbState === 'idle' ? 0.08 : orbState === 'typing' ? 0.15 : 0.25;
        const orbitSpeedMul = orbState === 'idle' ? 1 : orbState === 'typing' ? 2.5 : 5;
        const twinkleSpeed = orbState === 'idle' ? 0.02 : orbState === 'typing' ? 0.035 : 0.05;
        const rimBrightness = orbState === 'idle' ? 1 : orbState === 'typing' ? 1.3 : 1.6 + Math.sin(time * 8) * 0.2;

        // === Layer 1: Nebulae + Stars ===
        ctx!.globalCompositeOperation = 'lighter';
        nebulae.forEach(n => {
          const nr = Math.max(1, n.r);
          const ng = ctx!.createRadialGradient(n.x, n.y, 0, n.x, n.y, nr);
          ng.addColorStop(0, `rgba(${n.color}, 0.05)`);
          ng.addColorStop(0.5, `rgba(${n.color}, 0.03)`);
          ng.addColorStop(1, `rgba(${n.color}, 0)`);
          ctx!.fillStyle = ng;
          ctx!.beginPath();
          ctx!.arc(n.x, n.y, nr, 0, Math.PI * 2);
          ctx!.fill();
        });

        bgStars.forEach(p => {
          p.x += p.vx;
          p.y += p.vy;
          p.twinkle += twinkleSpeed;
          if (p.x < 0) p.x = w;
          if (p.x > w) p.x = 0;
          if (p.y < 0) p.y = h;
          if (p.y > h) p.y = 0;
          const twinkleAlpha = p.alpha * (0.5 + Math.sin(p.twinkle) * 0.5);
          ctx!.fillStyle = `rgba(${p.color}, ${twinkleAlpha})`;
          ctx!.beginPath();
          ctx!.arc(p.x, p.y, p.size, 0, Math.PI * 2);
          ctx!.fill();
        });

        // === Layer 2: Outer glow / nebula halo ===
        const glowR = Math.max(1, baseR * 8);
        const glow = ctx!.createRadialGradient(cx, cy, 0, cx, cy, glowR);
        glow.addColorStop(0, `rgba(99, 102, 241, ${glowAlpha})`);
        glow.addColorStop(0.3, `rgba(139, 92, 246, ${glowAlpha * 0.5})`);
        glow.addColorStop(0.6, `rgba(6, 182, 212, ${glowAlpha * 0.15})`);
        glow.addColorStop(1, 'rgba(6, 182, 212, 0)');
        ctx!.fillStyle = glow;
        ctx!.beginPath();
        ctx!.arc(cx, cy, glowR, 0, Math.PI * 2);
        ctx!.fill();

        // === Layer 3: Accretion disk rings ===
        for (let i = 0; i < ringCount; i++) {
          const ringR = Math.max(1, baseR * ringRadii[i]);
          const ringRy = Math.max(1, ringR * ringRyRatio[i]);
          const rot = time * ringRotSpeed[i] * orbitSpeedMul;
          ctx!.strokeStyle = ringColors[i];
          ctx!.lineWidth = ringWidths[i];
          ctx!.beginPath();
          ctx!.ellipse(cx, cy, ringR, ringRy, rot + ringTilt[i], 0, Math.PI * 2);
          ctx!.stroke();
        }

        // === Layer 4: Accretion disk particles ===
        diskParticles.forEach(p => {
          p.angle += p.speed * orbitSpeedMul;
          const ringR = Math.max(1, baseR * ringRadii[p.ringIdx]);
          const ringRy = Math.max(1, ringR * ringRyRatio[p.ringIdx]);
          const rot = time * ringRotSpeed[p.ringIdx] * orbitSpeedMul;
          const tilt = ringTilt[p.ringIdx];
          const cosR = Math.cos(rot + tilt);
          const sinR = Math.sin(rot + tilt);
          const localX = Math.cos(p.angle) * ringR;
          const localY = Math.sin(p.angle) * ringRy;
          const px = cx + localX * cosR - localY * sinR;
          const py = cy + localX * sinR + localY * cosR;

          const trailAngle = p.angle - p.speed * orbitSpeedMul * 4;
          const tLocalX = Math.cos(trailAngle) * ringR;
          const tLocalY = Math.sin(trailAngle) * ringRy;
          const tpx = cx + tLocalX * cosR - tLocalY * sinR;
          const tpy = cy + tLocalX * sinR + tLocalY * cosR;

          const isInner = p.ringIdx < 2;
          const isMiddle = p.ringIdx >= 2 && p.ringIdx < 5;
          const color = isInner ? '165, 243, 252' : isMiddle ? '129, 140, 248' : '167, 139, 250';

          ctx!.strokeStyle = `rgba(${color}, ${p.opacity * 0.4})`;
          ctx!.lineWidth = p.size * 0.8;
          ctx!.beginPath();
          ctx!.moveTo(tpx, tpy);
          ctx!.lineTo(px, py);
          ctx!.stroke();

          ctx!.fillStyle = `rgba(${color}, ${p.opacity})`;
          ctx!.beginPath();
          ctx!.arc(px, py, Math.max(0.5, p.size), 0, Math.PI * 2);
          ctx!.fill();

          const haloMul = isInner ? 3 : isMiddle ? 2 : 1.5;
          ctx!.fillStyle = `rgba(${color}, ${p.opacity * 0.25})`;
          ctx!.beginPath();
          ctx!.arc(px, py, Math.max(1, p.size * haloMul), 0, Math.PI * 2);
          ctx!.fill();
        });

        // === Layer 5: The core (singularity) ===
        ctx!.globalCompositeOperation = 'source-over';
        const coreOuterR = Math.max(1, r * 1.3);
        const coreGrad = ctx!.createRadialGradient(cx, cy, 0, cx, cy, coreOuterR);
        coreGrad.addColorStop(0, 'rgba(0, 0, 0, 1)');
        coreGrad.addColorStop(0.46, 'rgba(0, 0, 0, 0.9)');
        coreGrad.addColorStop(0.77, `rgba(165, 243, 252, ${Math.min(1, 0.8 * rimBrightness)})`);
        coreGrad.addColorStop(1, 'rgba(165, 243, 252, 0)');
        ctx!.fillStyle = coreGrad;
        ctx!.beginPath();
        ctx!.arc(cx, cy, coreOuterR, 0, Math.PI * 2);
        ctx!.fill();

        ctx!.fillStyle = 'rgba(0, 0, 0, 1)';
        ctx!.beginPath();
        ctx!.arc(cx, cy, Math.max(1, r * 0.7), 0, Math.PI * 2);
        ctx!.fill();

        // Bright rim glow (additive)
        ctx!.globalCompositeOperation = 'lighter';
        const rimGlowR = Math.max(1, r * 1.15);
        const rimInnerR = Math.max(1, r * 0.95);
        const rimGlow = ctx!.createRadialGradient(cx, cy, rimInnerR, cx, cy, rimGlowR);
        rimGlow.addColorStop(0, 'rgba(165, 243, 252, 0)');
        rimGlow.addColorStop(0.5, `rgba(165, 243, 252, ${Math.min(1, 0.6 * rimBrightness)})`);
        rimGlow.addColorStop(1, 'rgba(165, 243, 252, 0)');
        ctx!.fillStyle = rimGlow;
        ctx!.beginPath();
        ctx!.arc(cx, cy, rimGlowR, 0, Math.PI * 2);
        ctx!.fill();

        ctx!.strokeStyle = `rgba(224, 242, 254, ${Math.min(1, 0.9 * rimBrightness)})`;
        ctx!.lineWidth = 1.5;
        ctx!.beginPath();
        ctx!.arc(cx, cy, Math.max(1, r), 0, Math.PI * 2);
        ctx!.stroke();

        // Replying white-hot flash
        if (orbState === 'replying') {
          const flash = 0.25 + Math.sin(time * 6) * 0.15;
          ctx!.fillStyle = `rgba(255, 255, 255, ${Math.max(0, Math.min(1, flash))})`;
          ctx!.beginPath();
          ctx!.arc(cx, cy, Math.max(1, r * 0.75), 0, Math.PI * 2);
          ctx!.fill();
        }

        // === Layer 6: Polar data jets ===
        const jetTargetTotal = orbState === 'idle' ? 20 : orbState === 'typing' ? 40 : 60;
        const jetSpeed = orbState === 'idle' ? 1.0 : orbState === 'typing' ? 2.0 : 3.5;
        jetSpawnAccum = Math.min(jetSpawnAccum + jetTargetTotal / 80, 5);
        while (jetSpawnAccum >= 1 && jets.length < 70) {
          jetSpawnAccum -= 1;
          const up = Math.random() < 0.5;
          const angle = up ? jetAxisAngle : jetAxisAngle + Math.PI;
          const spread = (Math.random() - 0.5) * 0.2;
          const v = jetSpeed * (0.7 + Math.random() * 0.6);
          const spawnR = Math.max(1, r);
          const sx = cx + Math.cos(angle) * spawnR;
          const sy = cy + Math.sin(angle) * spawnR;
          jets.push({
            x: sx,
            y: sy,
            vx: Math.cos(angle + spread) * v,
            vy: Math.sin(angle + spread) * v,
            life: 0,
            maxLife: 60 + Math.random() * 40,
            size: 1 + Math.random() * 1.5,
            prevX: sx,
            prevY: sy,
          });
        }

        for (let i = jets.length - 1; i >= 0; i--) {
          const j = jets[i];
          j.prevX = j.x;
          j.prevY = j.y;
          j.x += j.vx;
          j.y += j.vy;
          j.life++;
          const lifeRatio = j.life / j.maxLife;
          const opacity = Math.max(0, 1 - lifeRatio) * 0.8;
          ctx!.strokeStyle = `rgba(224, 242, 254, ${opacity * 0.6})`;
          ctx!.lineWidth = j.size;
          ctx!.beginPath();
          ctx!.moveTo(j.prevX, j.prevY);
          ctx!.lineTo(j.x, j.y);
          ctx!.stroke();
          ctx!.fillStyle = `rgba(224, 242, 254, ${opacity})`;
          ctx!.beginPath();
          ctx!.arc(j.x, j.y, Math.max(0.5, j.size), 0, Math.PI * 2);
          ctx!.fill();
          if (j.life >= j.maxLife || j.x < -50 || j.x > w + 50 || j.y < -50 || j.y > h + 50) {
            jets.splice(i, 1);
          }
        }

        // === Layer 7: Spiral shockwaves (replying only) ===
        if (orbState === 'replying' && time - lastShockwaveTime > 1) {
          shockwaves.push({ r: baseR * 1.2, alpha: 0.6 });
          lastShockwaveTime = time;
        }
        for (let i = shockwaves.length - 1; i >= 0; i--) {
          const sw = shockwaves[i];
          sw.r += 2.5;
          sw.alpha *= 0.985;
          const swR = Math.max(1, sw.r);
          ctx!.strokeStyle = `rgba(165, 243, 252, ${Math.max(0, sw.alpha)})`;
          ctx!.lineWidth = 1.5;
          ctx!.beginPath();
          ctx!.arc(cx, cy, swR, 0, Math.PI * 2);
          ctx!.stroke();
          if (sw.r > baseR * 6 || sw.alpha < 0.01) {
            shockwaves.splice(i, 1);
          }
        }

        ctx!.globalCompositeOperation = 'source-over';
        requestAnimationFrame(draw);
      }
      draw();

      const resizeObs = new ResizeObserver(resize);
      resizeObs.observe(canvas);
    });
  }

  function setOrbState(state: OrbState) {
    orbState = state;
  }

  function getHistory(): Array<{ role: 'user' | 'ai'; text: string; ts: number }> {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); }
    catch { return []; }
  }
  function saveHistory(h: Array<{ role: 'user' | 'ai'; text: string; ts: number }>) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(h));
  }

  function createBubble(role: 'user' | 'ai', text: string): HTMLElement {
    const div = document.createElement('div');
    div.className = role === 'user'
      ? 'bg-indigo-600 text-white rounded-lg rounded-tr-sm p-3 text-sm ml-auto max-w-[80%] chat-bubble-enter font-body'
      : 'bg-[#1A1A1A] border border-white/8 rounded-lg rounded-tl-sm p-3 text-sm text-white/80 max-w-[85%] chat-bubble-enter font-body';
    div.textContent = text;
    return div;
  }

  function createTypingIndicator(): HTMLElement {
    const div = document.createElement('div');
    div.className = 'bg-[#1A1A1A] border border-white/8 rounded-lg rounded-tl-sm p-3 inline-flex gap-1';
    div.innerHTML = '<span class="typing-dot"></span><span class="typing-dot"></span><span class="typing-dot"></span>';
    return div;
  }

  function createExampleBubble(role: 'user' | 'ai', text: string): HTMLElement {
    const bubble = createBubble(role, text);
    bubble.classList.add('chat-example-bubble');
    bubble.setAttribute('data-example', 'true');
    if (role === 'ai') bubble.style.whiteSpace = 'pre-line';
    return bubble;
  }

  function initChat() {
    const messagesEl = document.querySelector('[data-chat-messages]') as HTMLElement | null;
    const inputEl = document.querySelector('[data-chat-input]') as HTMLInputElement | null;
    const sendBtn = document.querySelector('[data-chat-send]') as HTMLButtonElement | null;
    const placeholderEl = document.querySelector('[data-chat-placeholder]') as HTMLElement | null;
    if (!messagesEl || !inputEl || !sendBtn) return;

    messagesEl.innerHTML = '';
    const history = getHistory();
    if (history.length === 0) {
      // Show example conversation for first-time visitors
      EXAMPLE_CONVERSATION.forEach(msg => messagesEl.appendChild(createExampleBubble(msg.role, msg.text)));
    } else {
      history.forEach(msg => {
        const b = createBubble(msg.role, msg.text);
        if (msg.role === 'ai' && msg.text.includes('\n')) b.style.whiteSpace = 'pre-line';
        messagesEl.appendChild(b);
      });
    }
    messagesEl.scrollTop = messagesEl.scrollHeight;

    // Placeholder cursor toggle: hide blinking cursor when input is focused or has content
    function updatePlaceholder() {
      if (!placeholderEl) return;
      placeholderEl.style.display = (inputEl!.value !== '' || document.activeElement === inputEl) ? 'none' : '';
    }
    inputEl.addEventListener('focus', updatePlaceholder);
    inputEl.addEventListener('blur', updatePlaceholder);
    inputEl.addEventListener('input', updatePlaceholder);
    updatePlaceholder();

    function send() {
      const text = inputEl!.value.trim();
      if (!text) return;

      // Clear example bubbles on first real send
      messagesEl!.querySelectorAll('[data-example="true"]').forEach(el => el.remove());

      messagesEl!.appendChild(createBubble('user', text));
      setOrbState('typing');
      const hist = getHistory();
      hist.push({ role: 'user', text, ts: Date.now() });
      saveHistory(hist);
      inputEl!.value = '';
      updatePlaceholder();
      messagesEl!.scrollTop = messagesEl!.scrollHeight;

      setTimeout(() => {
        const typing = createTypingIndicator();
        setOrbState('replying');
        messagesEl!.appendChild(typing);
        messagesEl!.scrollTop = messagesEl!.scrollHeight;

        setTimeout(() => {
          typing.remove();
          setOrbState('idle');
          messagesEl!.appendChild(createBubble('ai', FAKE_AI_REPLY));
          const h2 = getHistory();
          h2.push({ role: 'ai', text: FAKE_AI_REPLY, ts: Date.now() });
          saveHistory(h2);
          messagesEl!.scrollTop = messagesEl!.scrollHeight;
        }, 1500);
      }, 300);
    }

    sendBtn.addEventListener('click', send);
    inputEl.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); }
    });
  }

  function initDockDot() {
    const dot = document.querySelector('.chat-dock-dot') as HTMLElement | null;
    if (!dot) return;
    const hasHistory = getHistory().length > 0;
    dot.style.display = hasHistory ? 'block' : 'none';
  }

  initChat();
  initDockDot();
  initOrb();
  document.addEventListener('astro:page-load', () => { initChat(); initDockDot(); initOrb(); });
</script>
