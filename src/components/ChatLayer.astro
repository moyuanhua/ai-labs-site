---
interface Props {
  variant: 'hero' | 'dock' | 'fullscreen';
}
const { variant } = Astro.props;
const BASE = import.meta.env.BASE_URL;
---

{variant === 'hero' && (
  <div
    transition:name="chat-layer"
    class="chat-hero max-w-2xl mx-auto flex flex-col min-h-[320px] bg-zinc-950/85 backdrop-blur-xl border border-white/10 rounded-3xl overflow-hidden"
    style="box-shadow: var(--chat-glow);"
  >
    <div class="px-6 pt-5 pb-3">
      <p class="font-heading text-xl text-zinc-100 font-medium">Hi, I'm moyuanhua's AI.</p>
      <p class="font-body text-sm text-zinc-400 mt-1">Ask me about my work, demos, or writing.</p>
    </div>

    <div data-chat-messages class="flex-1 min-h-[180px] overflow-y-auto px-6 space-y-3"></div>

    <div class="p-4 border-t border-white/10 flex gap-2">
      <input
        data-chat-input
        type="text"
        placeholder="问我任何问题…"
        class="flex-1 bg-zinc-900/50 border border-zinc-700 rounded-xl px-4 py-3 text-zinc-100 placeholder-zinc-500 text-sm font-body focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/30"
      />
      <button
        data-chat-send
        type="button"
        class="bg-blue-600 hover:bg-blue-500 text-white rounded-xl px-4 py-3 text-sm font-body font-medium transition-colors cursor-pointer"
      >
        发送
      </button>
    </div>
  </div>
)}

{variant === 'dock' && (
  <a
    href={`${BASE}chat`}
    transition:name="chat-layer"
    data-chat-dock
    class="chat-dock fixed bottom-6 right-6 z-30 w-14 h-14 rounded-full bg-zinc-950/85 backdrop-blur-xl border border-white/10 flex items-center justify-center cursor-pointer"
    style="box-shadow: 0 0 30px rgba(37,99,235,0.3); transition: box-shadow 200ms ease-out;"
    aria-label="Open chat"
  >
    <svg
      width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
      stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
      class="text-blue-400 w-6 h-6" aria-hidden="true"
    >
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
    </svg>
    <span class="absolute top-0 right-0 w-3 h-3 bg-blue-500 rounded-full chat-dock-dot" style="display:none;"></span>
  </a>
)}

{variant === 'fullscreen' && (
  <div
    transition:name="chat-layer"
    class="chat-fullscreen fixed inset-0 z-50 bg-zinc-950/95 backdrop-blur-2xl flex flex-col"
  >
    <div class="max-w-3xl mx-auto w-full h-full flex flex-col">
      <header class="h-16 shrink-0 border-b border-white/10 px-6 flex items-center justify-between">
        <div class="flex items-center">
          <span class="font-heading text-lg text-zinc-100 font-medium">moyuanhua's AI</span>
          <span class="w-2 h-2 bg-emerald-400 rounded-full ml-2" aria-hidden="true"></span>
        </div>
        <button
          type="button"
          onclick="history.back()"
          class="text-zinc-400 hover:text-zinc-100 transition-colors cursor-pointer"
          aria-label="Close chat"
        >
          <svg
            width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
          >
            <path d="M18 6L6 18M6 6l12 12" />
          </svg>
        </button>
      </header>

      <div data-chat-messages class="flex-1 overflow-y-auto p-6 space-y-4"></div>

      <div class="p-6 shrink-0 border-t border-white/10 flex gap-3">
        <input
          data-chat-input
          type="text"
          placeholder="问我任何问题…"
          class="flex-1 bg-zinc-900/50 border border-zinc-700 rounded-xl px-4 py-3 text-zinc-100 placeholder-zinc-500 text-sm font-body focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/30"
        />
        <button
          data-chat-send
          type="button"
          class="bg-blue-600 hover:bg-blue-500 text-white rounded-xl px-6 py-3 text-sm font-body font-medium transition-colors cursor-pointer"
        >
          发送
        </button>
      </div>
    </div>
  </div>
)}

<script>
  const STORAGE_KEY = 'moyuanhua-chat-history';
  const FAKE_AI_REPLY = "I'm still being trained on moyuanhua's content. Once I'm live, I'll be able to answer questions about the blog, demos, and products. For now, feel free to browse the content on the other pages.";

  function getHistory(): Array<{ role: 'user' | 'ai'; text: string; ts: number }> {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); }
    catch { return []; }
  }
  function saveHistory(h: Array<{ role: 'user' | 'ai'; text: string; ts: number }>) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(h));
  }

  function createBubble(role: 'user' | 'ai', text: string): HTMLElement {
    const div = document.createElement('div');
    div.className = role === 'user'
      ? 'bg-blue-600 text-white rounded-2xl rounded-tr-sm p-3 text-sm ml-auto max-w-[80%] chat-bubble-enter font-body'
      : 'bg-zinc-800/60 border border-zinc-700 rounded-2xl rounded-tl-sm p-3 text-sm text-zinc-100 max-w-[85%] chat-bubble-enter font-body';
    div.textContent = text;
    return div;
  }

  function createTypingIndicator(): HTMLElement {
    const div = document.createElement('div');
    div.className = 'bg-zinc-800/60 border border-zinc-700 rounded-2xl rounded-tl-sm p-3 inline-flex gap-1';
    div.innerHTML = '<span class="typing-dot"></span><span class="typing-dot"></span><span class="typing-dot"></span>';
    return div;
  }

  function initChat() {
    const messagesEl = document.querySelector('[data-chat-messages]') as HTMLElement | null;
    const inputEl = document.querySelector('[data-chat-input]') as HTMLInputElement | null;
    const sendBtn = document.querySelector('[data-chat-send]') as HTMLButtonElement | null;
    if (!messagesEl || !inputEl || !sendBtn) return;

    messagesEl.innerHTML = '';
    const history = getHistory();
    history.forEach(msg => messagesEl.appendChild(createBubble(msg.role, msg.text)));
    messagesEl.scrollTop = messagesEl.scrollHeight;

    function send() {
      const text = inputEl!.value.trim();
      if (!text) return;

      messagesEl!.appendChild(createBubble('user', text));
      const hist = getHistory();
      hist.push({ role: 'user', text, ts: Date.now() });
      saveHistory(hist);
      inputEl!.value = '';
      messagesEl!.scrollTop = messagesEl!.scrollHeight;

      setTimeout(() => {
        const typing = createTypingIndicator();
        messagesEl!.appendChild(typing);
        messagesEl!.scrollTop = messagesEl!.scrollHeight;

        setTimeout(() => {
          typing.remove();
          messagesEl!.appendChild(createBubble('ai', FAKE_AI_REPLY));
          const h2 = getHistory();
          h2.push({ role: 'ai', text: FAKE_AI_REPLY, ts: Date.now() });
          saveHistory(h2);
          messagesEl!.scrollTop = messagesEl!.scrollHeight;
        }, 1500);
      }, 300);
    }

    sendBtn.addEventListener('click', send);
    inputEl.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); }
    });
  }

  function initDockDot() {
    const dot = document.querySelector('.chat-dock-dot') as HTMLElement | null;
    if (!dot) return;
    const hasHistory = getHistory().length > 0;
    dot.style.display = hasHistory ? 'block' : 'none';
  }

  initChat();
  initDockDot();
  document.addEventListener('astro:page-load', () => { initChat(); initDockDot(); });
</script>
