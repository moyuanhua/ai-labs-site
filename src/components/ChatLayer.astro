---
interface Props {
  variant: 'hero' | 'dock' | 'fullscreen';
}
const { variant } = Astro.props;
const BASE = import.meta.env.BASE_URL;
---

{variant === 'hero' && (
  <div
    transition:name="chat-layer"
    class="chat-hero relative flex flex-col min-h-screen bg-slate-50 overflow-hidden"
  >
    {/* Top status bar */}
    <div class="relative shrink-0 px-6 sm:px-10 lg:px-16 xl:px-24 pt-6 pb-4 flex items-center justify-between border-b border-slate-200">
      <div class="flex items-center gap-3">
        <span class="font-heading text-2xl sm:text-3xl text-slate-900 font-semibold tracking-tight">moyuanhua</span>
      </div>
      <div class="flex items-center gap-2 text-sm text-slate-500">
        <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
        <span>online</span>
      </div>
    </div>

    {/* Greeting + messages */}
    <div class="relative flex-1 flex flex-col justify-center w-full px-6 sm:px-10 lg:px-16 xl:px-24 py-8">
      <div class="mb-6">
        <p class="font-heading text-xl sm:text-2xl text-slate-900 font-medium mb-2">
          Hi, I'm moyuanhua's AI.
        </p>
        <p class="font-body text-sm sm:text-base text-slate-500 leading-relaxed max-w-lg">
          Ask me about my work, demos, or writing. I'm trained on everything on this site.
        </p>
      </div>

      <div data-chat-messages class="flex-1 min-h-[160px] max-h-[40vh] overflow-y-auto space-y-3 pr-2"></div>
    </div>

    {/* Bottom input bar */}
    <div class="relative shrink-0 border-t border-slate-200 bg-white">
      <div class="w-full px-6 sm:px-10 lg:px-16 xl:px-24 py-5 flex gap-3 items-center">
        <input
          data-chat-input
          type="text"
          placeholder="ask me anything…"
          class="flex-1 bg-transparent border-none text-slate-900 placeholder-slate-400 text-sm sm:text-base font-body focus:outline-none"
        />
        <button
          data-chat-send
          type="button"
          class="shrink-0 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg px-5 py-2 transition-colors cursor-pointer"
        >
          Send
        </button>
      </div>
    </div>
  </div>
)}

{variant === 'dock' && (
  <a
    href={`${BASE}chat`}
    transition:name="chat-layer"
    data-chat-dock
    class="chat-dock fixed bottom-6 right-6 z-30 w-14 h-14 rounded-full bg-white border border-slate-200 shadow-sm hover:shadow-md hover:border-indigo-300 flex items-center justify-center cursor-pointer transition-all duration-200"
    aria-label="Open chat"
  >
    <svg
      width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
      stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
      class="text-indigo-600 w-6 h-6" aria-hidden="true"
    >
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
    </svg>
    <span class="absolute top-0 right-0 w-3 h-3 bg-indigo-600 rounded-full chat-dock-dot" style="display:none;"></span>
  </a>
)}

{variant === 'fullscreen' && (
  <div
    transition:name="chat-layer"
    class="chat-fullscreen relative fixed inset-0 z-50 bg-slate-50 flex flex-col overflow-hidden"
  >
    <div class="relative flex-1 flex flex-col w-full">
      <header class="shrink-0 px-6 sm:px-10 lg:px-16 xl:px-24 pt-6 pb-4 flex items-center justify-between border-b border-slate-200">
        <div class="flex items-center gap-3">
          <span class="font-heading text-lg text-slate-900 font-medium">moyuanhua's AI</span>
          <span class="w-2 h-2 bg-emerald-500 rounded-full" aria-hidden="true"></span>
        </div>
        <div class="flex items-center gap-4">
          <span class="text-sm text-slate-500 hidden sm:inline">online</span>
          <button
            type="button"
            onclick="history.back()"
            class="text-slate-400 hover:text-slate-900 transition-colors cursor-pointer"
            aria-label="Close chat"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
            >
              <path d="M18 6L6 18M6 6l12 12" />
            </svg>
          </button>
        </div>
      </header>

      <div data-chat-messages class="relative flex-1 overflow-y-auto px-6 sm:px-10 lg:px-16 xl:px-24 py-6 space-y-4"></div>

      <div class="relative shrink-0 border-t border-slate-200 bg-white">
        <div class="px-6 sm:px-10 lg:px-16 xl:px-24 py-5 flex gap-3 items-center">
          <input
            data-chat-input
            type="text"
            placeholder="ask me anything…"
            class="flex-1 bg-transparent border-none text-slate-900 placeholder-slate-400 text-sm sm:text-base font-body focus:outline-none"
          />
          <button
            data-chat-send
            type="button"
            class="shrink-0 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg px-5 py-2 transition-colors cursor-pointer"
          >
            Send
          </button>
        </div>
      </div>
    </div>
  </div>
)}

<script>
  const STORAGE_KEY = 'moyuanhua-chat-history';
  const FAKE_AI_REPLY = "I'm still being trained on moyuanhua's content. Once I'm live, I'll be able to answer questions about the blog, demos, and products. For now, feel free to browse the content on the other pages.";

  function getHistory(): Array<{ role: 'user' | 'ai'; text: string; ts: number }> {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); }
    catch { return []; }
  }
  function saveHistory(h: Array<{ role: 'user' | 'ai'; text: string; ts: number }>) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(h));
  }

  function createBubble(role: 'user' | 'ai', text: string): HTMLElement {
    const div = document.createElement('div');
    div.className = role === 'user'
      ? 'bg-indigo-600 text-white rounded-lg rounded-tr-sm p-3 text-sm ml-auto max-w-[80%] chat-bubble-enter font-body'
      : 'bg-white border border-slate-200 rounded-lg rounded-tl-sm p-3 text-sm text-slate-700 max-w-[85%] chat-bubble-enter font-body';
    div.textContent = text;
    return div;
  }

  function createTypingIndicator(): HTMLElement {
    const div = document.createElement('div');
    div.className = 'bg-white border border-slate-200 rounded-lg rounded-tl-sm p-3 inline-flex gap-1';
    div.innerHTML = '<span class="typing-dot"></span><span class="typing-dot"></span><span class="typing-dot"></span>';
    return div;
  }

  function initChat() {
    const messagesEl = document.querySelector('[data-chat-messages]') as HTMLElement | null;
    const inputEl = document.querySelector('[data-chat-input]') as HTMLInputElement | null;
    const sendBtn = document.querySelector('[data-chat-send]') as HTMLButtonElement | null;
    if (!messagesEl || !inputEl || !sendBtn) return;

    messagesEl.innerHTML = '';
    const history = getHistory();
    history.forEach(msg => messagesEl.appendChild(createBubble(msg.role, msg.text)));
    messagesEl.scrollTop = messagesEl.scrollHeight;

    function send() {
      const text = inputEl!.value.trim();
      if (!text) return;

      messagesEl!.appendChild(createBubble('user', text));
      const hist = getHistory();
      hist.push({ role: 'user', text, ts: Date.now() });
      saveHistory(hist);
      inputEl!.value = '';
      messagesEl!.scrollTop = messagesEl!.scrollHeight;

      setTimeout(() => {
        const typing = createTypingIndicator();
        messagesEl!.appendChild(typing);
        messagesEl!.scrollTop = messagesEl!.scrollHeight;

        setTimeout(() => {
          typing.remove();
          messagesEl!.appendChild(createBubble('ai', FAKE_AI_REPLY));
          const h2 = getHistory();
          h2.push({ role: 'ai', text: FAKE_AI_REPLY, ts: Date.now() });
          saveHistory(h2);
          messagesEl!.scrollTop = messagesEl!.scrollHeight;
        }, 1500);
      }, 300);
    }

    sendBtn.addEventListener('click', send);
    inputEl.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); }
    });
  }

  function initDockDot() {
    const dot = document.querySelector('.chat-dock-dot') as HTMLElement | null;
    if (!dot) return;
    const hasHistory = getHistory().length > 0;
    dot.style.display = hasHistory ? 'block' : 'none';
  }

  initChat();
  initDockDot();
  document.addEventListener('astro:page-load', () => { initChat(); initDockDot(); });
</script>
